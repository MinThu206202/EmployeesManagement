@model EmployeesManagement.Models.LeaveAdjustmentEntry

@{
    ViewData["Title"] = "Adjust Leave Balance";
}

<div
    class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden">

    <form asp-action="AdjustLeaveBalance" method="post" class="p-6 md:p-8">

        <!-- Validation -->
        <div asp-validation-summary="ModelOnly"
             class="mb-6 p-4 bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 text-sm rounded-lg border border-red-100 dark:border-red-800">
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-6">

            <!-- Section -->
            <div class="md:col-span-2 flex items-center gap-2 border-b border-gray-100 dark:border-gray-700 pb-2">
                <i class="bi bi-sliders text-blue-500"></i>
                <h3 class="text-sm font-bold uppercase tracking-wider text-gray-400">
                    Leave Adjustment Details
                </h3>
            </div>

            <!-- Employee Dropdown -->
            <div class="space-y-1">
                <label asp-for="EmployeeId" class="block text-sm font-semibold text-gray-700 dark:text-gray-300">
                    Employee
                </label>

                <select asp-for="EmployeeId" asp-items="@(ViewData["EmployeeId"] as SelectList)"
                        class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none dark:text-white">
                    <option value="">-- Select Employee --</option>
                </select>

                <span asp-validation-for="EmployeeId" class="text-xs text-red-500"></span>
            </div>

            <!-- Adjustment Type Dropdown -->
            <div class="space-y-1">
                <label asp-for="AdjustmentTypeId" class="block text-sm font-semibold text-gray-700 dark:text-gray-300">
                    Adjustment Type
                </label>

                <select asp-for="AdjustmentTypeId" asp-items="@(ViewData["AdjustmentTypeId"] as SelectList)"
                        class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none dark:text-white">
                    <option value="">-- Select Type --</option>
                </select>

                <span asp-validation-for="AdjustmentTypeId" class="text-xs text-red-500"></span>
            </div>

            <!-- Leave Period -->
            <div class="space-y-1">
                <label asp-for="LeavePeriodId" class="block text-sm font-semibold text-gray-700 dark:text-gray-300">
                    Leave Period
                </label>

                <select asp-for="LeavePeriodId" asp-items="ViewBag.LeavePeriodId"
                        class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none dark:text-white">

                    <option value="">-- Select Leave Period --</option>

                </select>

                <span asp-validation-for="LeavePeriodId" class="text-xs text-red-500"></span>
            </div>

            <!-- No Of Days -->
            <div class="space-y-1">
                <label asp-for="NoOfDays" class="block text-sm font-semibold text-gray-700 dark:text-gray-300">
                    Number Of Days
                </label>

                <input asp-for="NoOfDays" type="number"
                       class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none dark:text-white"
                       placeholder="e.g. 2" />

                <span asp-validation-for="NoOfDays" class="text-xs text-red-500"></span>
            </div>

            <!-- Adjustment Date -->
            <div class="space-y-1">
                <label asp-for="LeaveAdjustmentDate"
                       class="block text-sm font-semibold text-gray-700 dark:text-gray-300">
                    Adjustment Date
                </label>

                <input asp-for="LeaveAdjustmentDate" type="date"
                       class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none dark:text-white" />

                <span asp-validation-for="LeaveAdjustmentDate" class="text-xs text-red-500"></span>
            </div>

            <!-- Description -->
            <div class="space-y-1 md:col-span-2">
                <label asp-for="AdjustmentDescription"
                       class="block text-sm font-semibold text-gray-700 dark:text-gray-300">
                    Description
                </label>

                <textarea asp-for="AdjustmentDescription" rows="3"
                          class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none dark:text-white"
                          placeholder="Reason for adjustment..."></textarea>

                <span asp-validation-for="AdjustmentDescription" class="text-xs text-red-500"></span>
            </div>

            <!-- Buttons -->
            <div
                class="mt-10 flex justify-end space-x-4 border-t border-gray-100 dark:border-gray-700 pt-6 md:col-span-2">

                <a asp-action="Index"
                       class="px-6 py-2.5 text-sm font-semibold text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700 rounded-lg">
                    Cancel
                </a>

                <button type="submit"
                        class="inline-flex items-center px-8 py-2.5 bg-blue-600 hover:bg-blue-700 text-white text-sm font-bold rounded-lg shadow-md">
                    <i class="bi bi-check2-circle mr-2"></i>
                    Save Adjustment
                </button>

            </div>

        </div>
    </form>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
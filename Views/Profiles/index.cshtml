@model EmployeesManagement.ViewModels.ProfileViewModel

@{
    ViewData["Title"] = "Assign Role Rights";
}

<!-- Header -->
<div class="flex items-center justify-between mb-4">
    <div>
        <h1 class="text-2xl font-extrabold text-gray-900 dark:text-white tracking-tight">
            Assign Role Rights
        </h1>
        <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5 flex items-center">
            <i class="bi bi-diagram-3 mr-1.5 text-indigo-500"></i>
            Assign system tasks to roles
        </p>
    </div>
</div>

<!-- Card -->
<div
    class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-xl shadow-lg overflow-hidden max-w-xl">

    <form asp-action="AssignRights" method="post">

        <!-- Validation -->
        <div asp-validation-summary="ModelOnly" class="px-6 py-2 bg-rose-50 dark:bg-rose-900/20 text-rose-600 text-xs">
        </div>

        <div class="p-8 space-y-6">

            <!-- Section Title -->
            <div class="flex items-center mb-2">
                <span class="w-6 h-6 flex items-center justify-center rounded-full bg-indigo-100 text-indigo-600 mr-2">
                    <i class="bi bi-shield-check text-[10px]"></i>
                </span>
                <h3 class="text-[11px] font-bold uppercase tracking-widest text-gray-500">
                    Assign Rights
                </h3>
            </div>

            <!-- Role Dropdown -->
            <div class="space-y-1">
                <label class="text-xs font-bold text-gray-700 ml-1">
                    Select Role
                </label>

                <select asp-for="RoleId" asp-items="ViewBag.Roles"
                        class="w-full px-3 py-2 border rounded-lg text-sm shadow-sm focus:ring-2 focus:ring-indigo-500">
                    <option value="">-- Select Role --</option>
                </select>

                <span asp-validation-for="RoleId" class="text-rose-500 text-xs"></span>
            </div>

            <!-- Task Dropdown -->
            <div class="space-y-1">
                <label class="text-xs font-bold text-gray-700 ml-1">
                    Select Task
                </label>

                <select asp-for="TaskId" asp-items="ViewBag.Tasks"
                        class="w-full px-3 py-2 border rounded-lg text-sm shadow-sm focus:ring-2 focus:ring-indigo-500">
                    <option value="">-- Select Task --</option>
                </select>

                <span asp-validation-for="TaskId" class="text-rose-500 text-xs"></span>
            </div>

        </div>

        <!-- Footer -->
        <div class="flex items-center justify-between px-6 py-4 border-t bg-gray-50 dark:bg-gray-800/50">

            <p class="text-[9px] text-gray-400 uppercase font-black tracking-widest">
                Role Permissions
            </p>

            <div class="flex space-x-3 w-full sm:w-auto">

                <a asp-action="Index"
                       class="flex-1 text-center px-4 py-2 text-xs font-bold text-gray-600 hover:bg-gray-200 rounded-lg">
                    Cancel
                </a>

                <button type="submit"
                        class="flex-1 px-6 py-2 text-xs font-bold text-white bg-indigo-600 rounded-lg shadow hover:bg-indigo-700 transition">
                    Assign
                </button>

            </div>

        </div>

    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
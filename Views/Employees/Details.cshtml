<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Employee Profile - Management System</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap');

        body { 
            font-family: 'Inter', sans-serif;
            background-color: #f8fafc;
        }
        
        .font-mono-sys { font-family: 'JetBrains Mono', monospace; }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .anim-fade { animation: fadeIn 0.5s ease-out both; }
        .delay-1 { animation-delay: 0.1s; }
        .delay-2 { animation-delay: 0.2s; }
        .delay-3 { animation-delay: 0.3s; }

        .glass-card {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(8px);
            border: 1px solid rgba(226, 232, 240, 0.8);
        }

        .status-badge-active {
            background: #ecfdf5;
            color: #059669;
            border: 1px solid #a7f3d0;
        }

        .sidebar-label {
            color: #64748b;
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        /* Custom print styling */
        @@media print {
            .no-print { display: none; }
            body { background: white; }
            .profile-root { max-width: 100%; padding: 0; }
        }
    </style>
</head>
<body>

<div class="profile-root max-w-6xl mx-auto px-4 sm:px-6 py-8">

    <!-- Header Navigation -->
    <div class="flex items-center justify-between mb-6 anim-fade no-print">
        <a asp-action="Index" class="inline-flex items-center px-3 py-2 text-sm font-medium text-slate-600 rounded-lg hover:bg-slate-100 transition-all">
            <i class="bi bi-chevron-left mr-2"></i> Personnel Directory
        </a>
        <div class="flex gap-3">
            <button onclick="window.print()" class="p-2.5 text-slate-500 bg-white border border-slate-200 rounded-lg hover:bg-slate-50 transition-colors shadow-sm">
                <i class="bi bi-printer"></i>
            </button>
            <a asp-action="Edit" asp-route-id="@@item.Id" class="inline-flex items-center px-5 py-2.5 bg-blue-600 text-white text-sm font-semibold rounded-lg hover:bg-blue-700 transition-all shadow-md shadow-blue-200 active:scale-95">
                <i class="bi bi-pencil-square mr-2"></i> Edit Record
            </a>
        </div>
    </div>

    <!-- ══ EMPLOYEE MASTHEAD ══ -->
    <div class="anim-fade relative bg-gradient-to-br from-slate-900 to-blue-900 rounded-2xl overflow-hidden mb-8 shadow-xl shadow-blue-900/10">
        <!-- Decorative Background Pattern -->
        <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(#fff 1px, transparent 1px); background-size: 20px 20px;"></div>
        
        <div class="relative z-10 p-6 sm:p-10">
            <div class="flex flex-col md:flex-row items-center md:items-start gap-8">
                
                <!-- Avatar with Status -->
                <div class="relative">
                    <div class="w-28 h-28 sm:w-32 sm:h-32 rounded-3xl bg-white/10 backdrop-blur-md border border-white/20 flex items-center justify-center shadow-2xl">
                        <span class="text-4xl font-extrabold text-white">
                            JD
                        </span>
                    </div>
                    <div class="absolute -bottom-2 -right-2 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider status-badge-active shadow-lg">
                        Active
                    </div>
                </div>

                <!-- Identity -->
                <div class="flex-1 text-center md:text-left">
                    <div class="flex flex-wrap justify-center md:justify-start items-center gap-3 mb-3">
                        <span class="font-mono-sys text-[11px] px-2 py-0.5 bg-blue-500/20 text-blue-100 rounded border border-white/10 uppercase tracking-wider">
                            ID: #EMP-8821
                        </span>
                        <span class="text-blue-200/60 text-xs">•</span>
                        <span class="text-blue-100/80 text-xs font-medium uppercase tracking-widest">Departmental Lead</span>
                    </div>
                    
                    <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-white tracking-tight mb-2">
                        John Alexander Doe
                    </h1>
                    
                    <div class="flex flex-wrap justify-center md:justify-start items-center gap-x-6 gap-y-2 mt-4 text-blue-100/70">
                        <div class="flex items-center text-sm">
                            <i class="bi bi-briefcase mr-2 text-blue-400"></i> Senior Solutions Architect
                        </div>
                        <div class="flex items-center text-sm">
                            <i class="bi bi-building mr-2 text-blue-400"></i> Engineering & Technology
                        </div>
                        <div class="flex items-center text-sm">
                            <i class="bi bi-geo-alt mr-2 text-blue-400"></i> United Kingdom
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ══ CONTENT GRID ══ -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">

        <!-- Sidebar (4 cols) -->
        <div class="lg:col-span-4 space-y-6 anim-fade delay-1">
            
            <!-- Contact Card -->
            <div class="glass-card rounded-2xl p-6 shadow-sm">
                <div class="flex items-center justify-between mb-6">
                    <h3 class="sidebar-label">Contact Details</h3>
                    <div class="w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center text-blue-600">
                        <i class="bi bi-chat-left-dots"></i>
                    </div>
                </div>
                
                <div class="space-y-5">
                    <div class="group">
                        <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest mb-1">Business Email</p>
                        <a href="mailto:j.doe@enterprise.com" class="text-sm font-semibold text-slate-800 hover:text-blue-600 transition-colors break-all flex items-center">
                            j.doe@enterprise.com
                            <i class="bi bi-arrow-up-right text-[10px] ml-1 opacity-0 group-hover:opacity-100 transition-opacity"></i>
                        </a>
                    </div>
                    <div class="group">
                        <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest mb-1">Mobile Phone</p>
                        <p class="text-sm font-semibold text-slate-800 flex items-center">
                            +44 7700 900123
                        </p>
                    </div>
                </div>
            </div>

            <!-- Vital Stats -->
            <div class="bg-blue-600 rounded-2xl p-6 text-white shadow-lg shadow-blue-200 relative overflow-hidden group">
                <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:scale-110 transition-transform duration-500">
                    <i class="bi bi-calendar-event text-6xl"></i>
                </div>
                <div class="relative z-10">
                    <p class="text-blue-100/60 text-[10px] font-bold uppercase tracking-widest mb-1">Date of Birth</p>
                    <p class="text-2xl font-bold tracking-tight mb-4">January 14, 1988</p>
                    <div class="inline-flex items-center px-2 py-1 bg-white/10 rounded-md text-[10px] font-bold uppercase tracking-tighter border border-white/10">
                        Verified Record
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Panel (8 cols) -->
        <div class="lg:col-span-8 space-y-6 anim-fade delay-2">
            
            <!-- Employment Details -->
            <div class="glass-card rounded-2xl shadow-sm overflow-hidden">
                <div class="px-8 py-5 border-b border-slate-100 bg-slate-50/50 flex items-center justify-between">
                    <h3 class="text-xs font-bold text-slate-700 uppercase tracking-widest">Employment Profile</h3>
                    <span class="text-[10px] font-bold text-blue-500 bg-blue-50 px-2 py-0.5 rounded uppercase">Full-Time</span>
                </div>
                
                <div class="p-8">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        <div>
                            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Primary Department</label>
                            <div class="flex items-center p-3 bg-slate-50 rounded-xl border border-slate-100">
                                <i class="bi bi-diagram-3 mr-3 text-slate-400"></i>
                                <span class="text-sm font-semibold text-slate-700">Engineering & Technology</span>
                            </div>
                        </div>
                        <div>
                            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Job Title / Role</label>
                            <div class="flex items-center p-3 bg-slate-50 rounded-xl border border-slate-100">
                                <i class="bi bi-person-badge mr-3 text-slate-400"></i>
                                <span class="text-sm font-semibold text-slate-700">Senior Solutions Architect</span>
                            </div>
                        </div>
                        <div class="md:col-span-2">
                            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Registered Work Address</label>
                            <div class="flex items-start p-4 bg-slate-50 rounded-xl border border-slate-100">
                                <i class="bi bi-geo mr-3 mt-1 text-slate-400"></i>
                                <span class="text-sm text-slate-600 leading-relaxed">
                                    124 Savile Row, Mayfair,<br>
                                    London W1S 3PR, United Kingdom
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Audit Information -->
            <div class="bg-slate-800 rounded-2xl p-8 text-white anim-fade delay-3 shadow-sm">
                <div class="flex items-center gap-3 mb-8">
                    <div class="h-px bg-slate-600 flex-1"></div>
                    <span class="text-[10px] font-bold text-slate-400 uppercase tracking-[0.3em]">System Audit History</span>
                    <div class="h-px bg-slate-600 flex-1"></div>
                </div>
                
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
                    <div class="flex gap-4">
                        <div class="h-10 w-10 rounded-xl bg-slate-700 flex items-center justify-center text-slate-400 shrink-0">
                            <i class="bi bi-plus-circle"></i>
                        </div>
                        <div>
                            <p class="text-[9px] font-bold text-slate-500 uppercase tracking-widest mb-1">Record Created</p>
                            <p class="text-sm font-bold text-slate-200">System Admin #1</p>
                            <p class="text-[11px] text-slate-400 mt-1">Mar 10, 2024 • 09:15 AM</p>
                        </div>
                    </div>
                    
                    <div class="flex gap-4">
                        <div class="h-10 w-10 rounded-xl bg-slate-700 flex items-center justify-center text-slate-400 shrink-0">
                            <i class="bi bi-clock-history"></i>
                        </div>
                        <div>
                            <p class="text-[9px] font-bold text-slate-500 uppercase tracking-widest mb-1">Last Modification</p>
                            <p class="text-sm font-bold text-slate-200">HR Manager #4</p>
                            <p class="text-[11px] text-slate-400 mt-1">Oct 22, 2024 • 14:30 PM</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

</body>
</html>
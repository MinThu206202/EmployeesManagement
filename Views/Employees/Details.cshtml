@model EmployeesManagement.Models.Employee

@{
    ViewData["Title"] = "Employee Details";
}

<script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<div class="max-w-6xl mx-auto px-4 py-8">

    <!-- Header -->
    <div class="flex justify-between mb-6">
        <a asp-action="Index" class="text-sm text-gray-600">← Back</a>

        <a asp-action="Edit" asp-route-id="@Model.Id" class="px-4 py-2 bg-blue-600 text-white rounded-lg text-sm">
            Edit
        </a>
    </div>

    <!-- Profile -->
    <div class="bg-gradient-to-r from-slate-900 to-blue-900 text-white p-6 rounded-xl mb-6">
        <h1 class="text-2xl font-bold">
            @Model.FirstName @Model.MiddleName @Model.LastName
        </h1>
        <p class="text-sm opacity-80">Employee No: @Model.EmpNo</p>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <!-- LEFT -->
        <div class="space-y-4">

            <div class="bg-white p-4 rounded-xl shadow">
                <p class="text-xs text-gray-400">Email</p>
                <p>@Model.EmailAddress</p>
            </div>

            <div class="bg-white p-4 rounded-xl shadow">
                <p class="text-xs text-gray-400">Phone</p>
                <p>@Model.PhoneNumber</p>
            </div>

            <div class="bg-white p-4 rounded-xl shadow">
                <p class="text-xs text-gray-400">Country</p>
                <p>@Model.Country?.Name</p>
            </div>

            <div class="bg-white p-4 rounded-xl shadow">
                <p class="text-xs text-gray-400">Gender</p>
                <p>@Model.Gender?.Description</p>
            </div>

            <div class="bg-blue-600 text-white p-4 rounded-xl">
                <p class="text-xs">Date of Birth</p>
                <p>@Model.DateOfBirth.ToString("dd MMM yyyy")</p>
            </div>

        </div>

        <!-- RIGHT -->
        <div class="lg:col-span-2 space-y-6">

            <!-- Employment -->
            <div class="bg-white p-6 rounded-xl shadow">
                <h3 class="text-sm font-bold mb-4">Employment Info</h3>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <p class="text-xs text-gray-400">Department</p>
                        <p>@Model.Department?.Name</p>
                    </div>

                    <div>
                        <p class="text-xs text-gray-400">Designation</p>
                        <p>@Model.Designation?.Name</p>
                    </div>

                    <div class="col-span-2">
                        <p class="text-xs text-gray-400">Address</p>
                        <p>@Model.Address</p>
                    </div>
                </div>
            </div>

            <!-- Audit -->
            <div class="bg-gray-800 text-white p-6 rounded-xl">
                <h3 class="text-sm font-bold mb-4">System Info</h3>

                <div class="grid grid-cols-2 gap-4 text-sm">
                    <div>
                        <p class="text-gray-400 text-xs">Created By</p>
                        <p>@Model.CreatedById</p>
                        <p class="text-gray-500 text-xs">
                            @Model.CreatedOn.ToString("dd MMM yyyy HH:mm")
                        </p>
                    </div>

                    <div>
                        <p class="text-gray-400 text-xs">Modified By</p>
                        <p>@Model.ModifiedById</p>
                        <p class="text-gray-500 text-xs">
                            @Model.ModifiedOn.ToString("dd MMM yyyy HH:mm")
                        </p>
                    </div>
                </div>
            </div>

        </div>

    </div>
</div>
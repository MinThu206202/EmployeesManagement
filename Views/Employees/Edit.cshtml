@model EmployeesManagement.Models.Employee

@{
    ViewData["Title"] = "Edit Employee Profile";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap');

    body { 
        font-family: 'Inter', sans-serif;
        background-color: #f8fafc;
    }
    
    .font-mono-sys { font-family: 'JetBrains Mono', monospace; }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .anim-fade { animation: fadeIn 0.5s ease-out both; }

    .glass-card {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(8px);
        border: 1px solid rgba(226, 232, 240, 0.8);
    }

    .form-input-focus:focus {
        border-color: #2563eb;
        box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.1);
        outline: none;
    }

    .section-label {
        color: #64748b;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
</style>

<div class="max-w-5xl mx-auto px-4 sm:px-6 py-8">

    <form asp-action="Edit">
        <div asp-validation-summary="ModelOnly" class="text-red-500 mb-6 p-4 bg-red-50 border border-red-100 rounded-xl text-sm"></div>
        <input type="hidden" asp-for="Id" />

        <!-- Header Navigation -->
        <div class="flex items-center justify-between mb-8 anim-fade">
            <div>
                <a asp-action="Index" class="inline-flex items-center px-3 py-2 text-sm font-medium text-slate-600 rounded-lg hover:bg-slate-100 transition-all">
                    <i class="bi bi-chevron-left mr-2"></i> Back to Directory
                </a>
                <h1 class="text-2xl font-bold text-slate-900 mt-2">Edit Personnel Record</h1>
            </div>
            <div class="flex gap-3">
                <button type="submit" class="inline-flex items-center px-6 py-2.5 bg-blue-600 text-white text-sm font-semibold rounded-lg hover:bg-blue-700 transition-all shadow-md shadow-blue-200 active:scale-95">
                    <i class="bi bi-check2-circle mr-2"></i> Save Changes
                </button>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            
            <!-- Left Sidebar: Key Identifiers -->
            <div class="space-y-6 anim-fade">
                <div class="glass-card rounded-2xl p-6 shadow-sm">
                    <h3 class="section-label mb-6">System Identifiers</h3>
                    
                    <div class="space-y-4">
                        <div>
                            <label asp-for="EmpNo" class="block text-xs font-semibold text-slate-500 mb-1">Employee ID Number</label>
                            <input asp-for="EmpNo" class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl text-sm font-mono-sys text-blue-700 form-input-focus transition-all" />
                            <span asp-validation-for="EmpNo" class="text-[10px] text-red-500 mt-1 block"></span>
                        </div>
                        
                        <div>
                            <label asp-for="Department" class="block text-xs font-semibold text-slate-500 mb-1">Assigned Department</label>
                            <input asp-for="Department" class="w-full px-4 py-2.5 bg-white border border-slate-200 rounded-xl text-sm form-input-focus transition-all" />
                            <span asp-validation-for="Department" class="text-[10px] text-red-500 mt-1 block"></span>
                        </div>

                        <div>
                            <label asp-for="Designation" class="block text-xs font-semibold text-slate-500 mb-1">Job Designation</label>
                            <input asp-for="Designation" class="w-full px-4 py-2.5 bg-white border border-slate-200 rounded-xl text-sm form-input-focus transition-all" />
                            <span asp-validation-for="Designation" class="text-[10px] text-red-500 mt-1 block"></span>
                        </div>
                    </div>
                </div>

                <div class="bg-slate-800 rounded-2xl p-6 text-white shadow-lg">
                    <h3 class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-4">Meta Information</h3>
                    <div class="space-y-4 opacity-80">
                        <div>
                            <label asp-for="CreatedById" class="block text-[9px] font-bold text-slate-500 uppercase mb-1">Creator ID</label>
                            <input asp-for="CreatedById" readonly class="w-full bg-slate-700/50 border-none rounded-lg text-xs py-2 px-3 text-slate-300" />
                        </div>
                        <div>
                            <label asp-for="CreatedOn" class="block text-[9px] font-bold text-slate-500 uppercase mb-1">Creation Date</label>
                            <input asp-for="CreatedOn" readonly class="w-full bg-slate-700/50 border-none rounded-lg text-xs py-2 px-3 text-slate-300" />
                        </div>
                        <input type="hidden" asp-for="ModifiedById" />
                        <input type="hidden" asp-for="ModifiedOn" />
                    </div>
                </div>
            </div>

            <!-- Main Panel: Personal & Contact Info -->
            <div class="lg:col-span-2 space-y-6 anim-fade" style="animation-delay: 0.1s;">
                
                <!-- Personal Information -->
                <div class="glass-card rounded-2xl shadow-sm overflow-hidden">
                    <div class="px-8 py-4 border-b border-slate-100 bg-slate-50/50">
                        <h3 class="section-label">Legal Name & Identity</h3>
                    </div>
                    <div class="p-8">
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                            <div>
                                <label asp-for="FirstName" class="block text-xs font-semibold text-slate-500 mb-1">First Name</label>
                                <input asp-for="FirstName" class="w-full px-4 py-2.5 bg-white border border-slate-200 rounded-xl text-sm form-input-focus transition-all" />
                                <span asp-validation-for="FirstName" class="text-[10px] text-red-500 mt-1 block"></span>
                            </div>
                            <div>
                                <label asp-for="MiddleName" class="block text-xs font-semibold text-slate-500 mb-1">Middle Name</label>
                                <input asp-for="MiddleName" class="w-full px-4 py-2.5 bg-white border border-slate-200 rounded-xl text-sm form-input-focus transition-all" />
                                <span asp-validation-for="MiddleName" class="text-[10px] text-red-500 mt-1 block"></span>
                            </div>
                            <div>
                                <label asp-for="LastName" class="block text-xs font-semibold text-slate-500 mb-1">Last Name</label>
                                <input asp-for="LastName" class="w-full px-4 py-2.5 bg-white border border-slate-200 rounded-xl text-sm form-input-focus transition-all" />
                                <span asp-validation-for="LastName" class="text-[10px] text-red-500 mt-1 block"></span>
                            </div>
                            <div class="md:col-span-2">
                                <label asp-for="DateOfBirth" class="block text-xs font-semibold text-slate-500 mb-1">Date of Birth</label>
                                <input asp-for="DateOfBirth" type="date" class="w-full px-4 py-2.5 bg-white border border-slate-200 rounded-xl text-sm form-input-focus transition-all" />
                                <span asp-validation-for="DateOfBirth" class="text-[10px] text-red-500 mt-1 block"></span>
                            </div>
                            <div>
                                <label asp-for="Country" class="block text-xs font-semibold text-slate-500 mb-1">Country</label>
                                <input asp-for="Country" class="w-full px-4 py-2.5 bg-white border border-slate-200 rounded-xl text-sm form-input-focus transition-all" />
                                <span asp-validation-for="Country" class="text-[10px] text-red-500 mt-1 block"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Contact & Location -->
                <div class="glass-card rounded-2xl shadow-sm overflow-hidden">
                    <div class="px-8 py-4 border-b border-slate-100 bg-slate-50/50">
                        <h3 class="section-label">Contact & Residential Details</h3>
                    </div>
                    <div class="p-8">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                            <div>
                                <label asp-for="EmailAddress" class="block text-xs font-semibold text-slate-500 mb-1">Email Address</label>
                                <div class="relative">
                                    <i class="bi bi-envelope absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"></i>
                                    <input asp-for="EmailAddress" class="w-full pl-11 pr-4 py-2.5 bg-white border border-slate-200 rounded-xl text-sm form-input-focus transition-all" />
                                </div>
                                <span asp-validation-for="EmailAddress" class="text-[10px] text-red-500 mt-1 block"></span>
                            </div>
                            <div>
                                <label asp-for="PhoneNumber" class="block text-xs font-semibold text-slate-500 mb-1">Phone Number</label>
                                <div class="relative">
                                    <i class="bi bi-telephone absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"></i>
                                    <input asp-for="PhoneNumber" class="w-full pl-11 pr-4 py-2.5 bg-white border border-slate-200 rounded-xl text-sm form-input-focus transition-all" />
                                </div>
                                <span asp-validation-for="PhoneNumber" class="text-[10px] text-red-500 mt-1 block"></span>
                            </div>
                        </div>
                        <div>
                            <label asp-for="Address" class="block text-xs font-semibold text-slate-500 mb-1">Residential Address</label>
                            <textarea asp-for="Address" rows="3" class="w-full px-4 py-2.5 bg-white border border-slate-200 rounded-xl text-sm form-input-focus transition-all"></textarea>
                            <span asp-validation-for="Address" class="text-[10px] text-red-500 mt-1 block"></span>
                        </div>
                    </div>
                </div>

                <div class="flex justify-end gap-3 pt-4">
                    <a asp-action="Index" class="px-6 py-2.5 text-sm font-semibold text-slate-600 hover:text-slate-800 transition-colors">Cancel</a>
                    <button type="submit" class="px-8 py-2.5 bg-blue-600 text-white text-sm font-bold rounded-xl hover:bg-blue-700 shadow-lg shadow-blue-100 transition-all">
                        Update Record
                    </button>
                </div>

            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
@model EmployeesManagement.Models.Employee

@{
    ViewData["Title"] = "Create New Employee";
}

<!-- Form Card -->
<div
    class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden">
    <form asp-action="Create" class="p-6 md:p-8">
        <div asp-validation-summary="ModelOnly"
             class="mb-6 p-4 bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 text-sm rounded-lg border border-red-100 dark:border-red-800">
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-6">
            
            <!-- Section 1: Personal -->
            <div class="md:col-span-2 flex items-center gap-2 border-b border-gray-100 dark:border-gray-700 pb-2">
                <i class="bi bi-person-circle text-blue-500"></i>
                <h3 class="text-sm font-bold uppercase tracking-wider text-gray-400">Personal Information</h3>
            </div>

            <div class="space-y-1">
                <label asp-for="EmpNo" class="block text-sm font-semibold text-gray-700 dark:text-gray-300">Employee ID
                    Number</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-gray-400">
                            <i class="bi bi-hash"></i>
                        </div>
                        <input asp-for="EmpNo"
                               class="w-full pl-10 pr-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all dark:text-white"
                               placeholder="e.g. EMP-1001" />
                    </div>
                    <span asp-validation-for="EmpNo" class="text-xs text-red-500"></span>
                </div>

                <div class="space-y-1">
                    <label asp-for="FirstName" class="block text-sm font-semibold text-gray-700 dark:text-gray-300">First
                        Name</label>
                        <input asp-for="FirstName"
                               class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all dark:text-white" />
                        <span asp-validation-for="FirstName" class="text-xs text-red-500"></span>
                    </div>

                    <div class="space-y-1">
                        <label asp-for="MiddleName" class="block text-sm font-semibold text-gray-700 dark:text-gray-300">Middle
                            Name</label>
                            <input asp-for="MiddleName"
                                   class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all dark:text-white" />
                            <span asp-validation-for="MiddleName" class="text-xs text-red-500"></span>
                        </div>

                        <div class="space-y-1">
                            <label asp-for="LastName" class="block text-sm font-semibold text-gray-700 dark:text-gray-300">Last
                                Name</label>
                                <input asp-for="LastName"
                                       class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all dark:text-white" />
                                <span asp-validation-for="LastName" class="text-xs text-red-500"></span>
                            </div>

                            <div class="space-y-1">
                                <label asp-for="DateOfBirth" class="block text-sm font-semibold text-gray-700 dark:text-gray-300">Date
                                    of Birth</label>
                                    <div class="relative">
                                        <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-gray-400">
                                            <i class="bi bi-calendar3"></i>
                                        </div>
                                        <input asp-for="DateOfBirth" type="date"
                                               class="w-full pl-10 pr-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all dark:text-white" />
                                    </div>
                                    <span asp-validation-for="DateOfBirth" class="text-xs text-red-500"></span>
                                </div>

                                <!-- Section 2: Contact -->
                                <div class="md:col-span-2 flex items-center gap-2 border-b border-gray-100 dark:border-gray-700 pb-2 mt-4">
                                    <i class="bi bi-envelope-at text-green-500"></i>
                                    <h3 class="text-sm font-bold uppercase tracking-wider text-gray-400">Contact & Location</h3>
                                </div>

                                <div class="space-y-1">
                                    <label asp-for="EmailAddress" class="block text-sm font-semibold text-gray-700 dark:text-gray-300">Email
                                        Address</label>
                                        <div class="relative">
                                            <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-gray-400">
                                                <i class="bi bi-envelope"></i>
                                            </div>
                                            <input asp-for="EmailAddress" type="email"
                                                   class="w-full pl-10 pr-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all dark:text-white"
                                                   placeholder="email@company.com" />
                                        </div>
                                        <span asp-validation-for="EmailAddress" class="text-xs text-red-500"></span>
                                    </div>

                                    <div class="space-y-1">
                                        <label asp-for="PhoneNumber" class="block text-sm font-semibold text-gray-700 dark:text-gray-300">Phone
                                            Number</label>
                                            <div class="relative">
                                                <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-gray-400">
                                                    <i class="bi bi-telephone"></i>
                                                </div>
                                                <input asp-for="PhoneNumber"
                                                       class="w-full pl-10 pr-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all dark:text-white" />
                                            </div>
                                            <span asp-validation-for="PhoneNumber" class="text-xs text-red-500"></span>
                                        </div>

                                        <div class="space-y-1">
                                            <label asp-for="Country"
                                                   class="block text-sm font-semibold text-gray-700 dark:text-gray-300">Country</label>
                                            <div class="relative">
                                                <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-gray-400">
                                                    <i class="bi bi-geo-alt"></i>
                                                </div>
                                                <input asp-for="Country"
                                                       class="w-full pl-10 pr-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all dark:text-white" />
                                            </div>
                                            <span asp-validation-for="Country" class="text-xs text-red-500"></span>
                                        </div>

                                        <div class="space-y-1 md:col-span-2">
                                            <label asp-for="Address"
                                                   class="block text-sm font-semibold text-gray-700 dark:text-gray-300">Residential Address</label>
                                            <div class="relative">
                                                <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-gray-400">
                                                    <i class="bi bi-house"></i>
                                                </div>
                                                <input asp-for="Address"
                                                       class="w-full pl-10 pr-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all dark:text-white" />
                                            </div>
                                            <span asp-validation-for="Address" class="text-xs text-red-500"></span>
                                        </div>

                                        <!-- Section 3: Professional -->
                                        <div class="md:col-span-2 flex items-center gap-2 border-b border-gray-100 dark:border-gray-700 pb-2 mt-4">
                                            <i class="bi bi-briefcase text-purple-500"></i>
                                            <h3 class="text-sm font-bold uppercase tracking-wider text-gray-400">Professional Details</h3>
                                        </div>

                                        <div class="space-y-1">
                                            <label asp-for="Department"
                                                   class="block text-sm font-semibold text-gray-700 dark:text-gray-300">Department</label>
                                            <div class="relative">
                                                <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-gray-400">
                                                    <i class="bi bi-building"></i>
                                                </div>
                                                <input asp-for="Department"
                                                       class="w-full pl-10 pr-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all dark:text-white" />
                                            </div>
                                            <span asp-validation-for="Department" class="text-xs text-red-500"></span>
                                        </div>

                                        <div class="space-y-1">
                                            <label asp-for="Designation"
                                                   class="block text-sm font-semibold text-gray-700 dark:text-gray-300">Designation</label>
                                            <div class="relative">
                                                <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-gray-400">
                                                    <i class="bi bi-person-badge"></i>
                                                </div>
                                                <input asp-for="Designation"
                                                       class="w-full pl-10 pr-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all dark:text-white" />
                                            </div>
                                            <span asp-validation-for="Designation" class="text-xs text-red-500"></span>
                                        </div>
                                    </div>

                                    <!-- Action Buttons -->
                                    <div class="mt-10 flex items-center justify-end space-x-4 border-t border-gray-100 dark:border-gray-700 pt-6">
                                        <a asp-action="Index"
                                               class="px-6 py-2.5 text-sm font-semibold text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700 rounded-lg transition-colors">
                                            Cancel
                                        </a>
                                        <button type="submit"
                                                class="inline-flex items-center px-8 py-2.5 bg-blue-600 hover:bg-blue-700 text-white text-sm font-bold rounded-lg shadow-md transition-all hover:shadow-lg transform hover:-translate-y-0.5">
                                            <i class="bi bi-check2-circle mr-2"></i>
                                            Save Employee
                                        </button>
                                    </div>
                                </form>
                            </div>


                            @section Scripts {
                                @{
                                    await Html.RenderPartialAsync("_ValidationScriptsPartial");
                                }
                            }
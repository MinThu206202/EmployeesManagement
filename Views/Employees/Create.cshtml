@model EmployeesManagement.Models.Employee

@{
    ViewData["Title"] = "Create New Employee";
}

<div
    class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden">
    <form asp-action="Create" method="post" class="p-6 md:p-8" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly"
             class="mb-6 p-4 bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 text-sm rounded-lg border border-red-100 dark:border-red-800">
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-6">
            <!-- Personal Section -->
            <div class="md:col-span-2 flex items-center gap-2 border-b border-gray-100 dark:border-gray-700 pb-2">
                <i class="bi bi-person-circle text-blue-500"></i>
                <h3 class="text-sm font-bold uppercase tracking-wider text-gray-400">Personal Information</h3>
            </div>

            <!-- Employee ID -->
            <div class="space-y-1">
                <label asp-for="EmpNo" class="block text-sm font-semibold text-gray-700 dark:text-gray-300">Employee
                    ID</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-gray-400">
                            <i class="bi bi-hash"></i>
                        </div>
                        <input asp-for="EmpNo"
                               class="w-full pl-10 pr-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all dark:text-white"
                               placeholder="e.g. EMP-1001" />
                    </div>
                    <span asp-validation-for="EmpNo" class="text-xs text-red-500"></span>
                </div>

                <!-- First Name -->
                <div class="space-y-1">
                    <label asp-for="FirstName" class="block text-sm font-semibold text-gray-700 dark:text-gray-300">First
                        Name</label>
                        <input asp-for="FirstName"
                               class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all dark:text-white" />
                        <span asp-validation-for="FirstName" class="text-xs text-red-500"></span>
                    </div>

                    <!-- Middle Name -->
                    <div class="space-y-1">
                        <label asp-for="MiddleName" class="block text-sm font-semibold text-gray-700 dark:text-gray-300">Middle
                            Name</label>
                            <input asp-for="MiddleName"
                                   class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all dark:text-white" />
                            <span asp-validation-for="MiddleName" class="text-xs text-red-500"></span>
                        </div>

                        <!-- Last Name -->
                        <div class="space-y-1">
                            <label asp-for="LastName" class="block text-sm font-semibold text-gray-700 dark:text-gray-300">Last
                                Name</label>
                                <input asp-for="LastName"
                                       class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all dark:text-white" />
                                <span asp-validation-for="LastName" class="text-xs text-red-500"></span>
                            </div>

                            <!-- Date of Birth -->
                            <div class="space-y-1">
                                <label asp-for="DateOfBirth" class="block text-sm font-semibold text-gray-700 dark:text-gray-300">Date
                                    of Birth</label>
                                    <input asp-for="DateOfBirth" type="date"
                                           class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all dark:text-white" />
                                    <span asp-validation-for="DateOfBirth" class="text-xs text-red-500"></span>
                                </div>

                                <!-- Address -->
                                <div class="space-y-1 md:col-span-2">
                                    <label asp-for="Address"
                                           class="block text-sm font-semibold text-gray-700 dark:text-gray-300">Address</label>
                                    <input asp-for="Address"
                                           class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all dark:text-white" />
                                    <span asp-validation-for="Address" class="text-xs text-red-500"></span>
                                </div>

                                <!-- Contact Section -->
                                <div class="md:col-span-2 flex items-center gap-2 border-b border-gray-100 dark:border-gray-700 pb-2 mt-4">
                                    <i class="bi bi-envelope-at text-green-500"></i>
                                    <h3 class="text-sm font-bold uppercase tracking-wider text-gray-400">Contact & Location</h3>
                                </div>

                                <!-- Email -->
                                <div class="space-y-1">
                                    <label asp-for="EmailAddress" class="block text-sm font-semibold text-gray-700 dark:text-gray-300">Email
                                        Address</label>
                                        <input asp-for="EmailAddress" type="email"
                                               class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all dark:text-white" />
                                        <span asp-validation-for="EmailAddress" class="text-xs text-red-500"></span>
                                    </div>

                                    <!-- Phone -->
                                    <div class="space-y-1">
                                        <label asp-for="PhoneNumber" class="block text-sm font-semibold text-gray-700 dark:text-gray-300">Phone
                                            Number</label>
                                            <input asp-for="PhoneNumber"
                                                   class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all dark:text-white" />
                                            <span asp-validation-for="PhoneNumber" class="text-xs text-red-500"></span>
                                        </div>

                                        <!-- Country Dropdown -->
                                        <div class="space-y-1">
                                            <label asp-for="CountryId"
                                                   class="block text-sm font-semibold text-gray-700 dark:text-gray-300">Country</label>
                                            <select asp-for="CountryId"
                                                    class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none dark:text-white"
                                                    asp-items="@(ViewData["CountrId"] as SelectList)">
                                                <option value="">-- Select Country --</option>
                                            </select>
                                            <span asp-validation-for="CountryId" class="text-xs text-red-500"></span>
                                        </div>

                                        <!-- Gender Dropdown -->
                                        <div class="space-y-1">
                                            <label asp-for="GenderId"
                                                   class="block text-sm font-semibold text-gray-700 dark:text-gray-300">Gender</label>
                                            <select asp-for="GenderId"
                                                    class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none dark:text-white"
                                                    asp-items="@(ViewData["GenderId"] as SelectList)">
                                                <option value="">-- Select Gender --</option>
                                            </select>
                                            <span asp-validation-for="GenderId" class="text-xs text-red-500"></span>
                                        </div>

                                        <!-- Profile Image -->
                                        <div class="space-y-1 md:col-span-2">
                                            <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300">
                                                Profile Image
                                            </label>

                                            <input type="file" name="employeephoto" accept=".png,.jpg,.jpeg"
                                                   class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all dark:text-white" />

                                        </div>

                                        <!-- Department Dropdown -->
                                        <div class="space-y-1">
                                            <label asp-for="DepartmentId"
                                                   class="block text-sm font-semibold text-gray-700 dark:text-gray-300">Department</label>
                                            <select asp-for="DepartmentId"
                                                    class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none dark:text-white"
                                                    asp-items="@(ViewData["DepartmentId"] as SelectList)">
                                                <option value="">-- Select Department --</option>
                                            </select>
                                            <span asp-validation-for="DepartmentId" class="text-xs text-red-500"></span>
                                        </div>

                                        <!-- Designation Dropdown -->
                                        <div class="space-y-1">
                                            <label asp-for="DesignationId"
                                                   class="block text-sm font-semibold text-gray-700 dark:text-gray-300">Designation</label>
                                            <select asp-for="DesignationId"
                                                    class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none dark:text-white"
                                                    asp-items="@(ViewData["DesignationId"] as SelectList)">
                                                <option value="">-- Select Designation --</option>
                                            </select>
                                            <span asp-validation-for="DesignationId" class="text-xs text-red-500"></span>
                                        </div>

                                        <!-- Employment & Bank Section -->
                                        <div class="md:col-span-2 flex items-center gap-2 border-b border-gray-100 dark:border-gray-700 pb-2 mt-4">
                                            <i class="bi bi-briefcase text-purple-500"></i>
                                            <h3 class="text-sm font-bold uppercase tracking-wider text-gray-400">
                                                Employment & Bank Details
                                            </h3>
                                        </div>

                                        <!-- Employment Date -->
                                        <div class="space-y-1">
                                            <label asp-for="EmployeeDate"
                                                   class="block text-sm font-semibold text-gray-700 dark:text-gray-300"></label>
                                            <input asp-for="EmployeeDate" type="date"
                                                   class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none dark:text-white" />
                                        </div>

                                        <!-- Bank -->
                                        <div class="space-y-1">
                                            <label asp-for="BankId" class="block text-sm font-semibold text-gray-700 dark:text-gray-300"></label>
                                            <select asp-for="BankId"
                                                    class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none dark:text-white"
                                                    asp-items="@(ViewData["BankId"] as SelectList)">
                                                <option value="">-- Select Bank --</option>
                                            </select>
                                        </div>

                                        <!-- Bank Account No -->
                                        <div class="space-y-1">
                                            <label asp-for="BankAccountNo"
                                                   class="block text-sm font-semibold text-gray-700 dark:text-gray-300"></label>
                                            <input asp-for="BankAccountNo"
                                                   class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none dark:text-white" />
                                        </div>

                                        <!-- IBAN -->
                                        <div class="space-y-1">
                                            <label asp-for="IBAN" class="block text-sm font-semibold text-gray-700 dark:text-gray-300"></label>
                                            <input asp-for="IBAN"
                                                   class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none dark:text-white" />
                                        </div>

                                        <!-- SWIFT Code -->
                                        <div class="space-y-1">
                                            <label asp-for="SWIFTCode" class="block text-sm font-semibold text-gray-700 dark:text-gray-300"></label>
                                            <input asp-for="SWIFTCode"
                                                   class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none dark:text-white" />
                                        </div>

                                        <!-- NSSF -->
                                        <div class="space-y-1">
                                            <label asp-for="NSSFNO" class="block text-sm font-semibold text-gray-700 dark:text-gray-300"></label>
                                            <input asp-for="NSSFNO"
                                                   class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none dark:text-white" />
                                        </div>

                                        <!-- NHIF -->
                                        <div class="space-y-1">
                                            <label asp-for="NHIF" class="block text-sm font-semibold text-gray-700 dark:text-gray-300"></label>
                                            <input asp-for="NHIF"
                                                   class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none dark:text-white" />
                                        </div>

                                        <!-- Company Email -->
                                        <div class="space-y-1">
                                            <label asp-for="CompanyEmail"
                                                   class="block text-sm font-semibold text-gray-700 dark:text-gray-300"></label>
                                            <input asp-for="CompanyEmail" type="email"
                                                   class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none dark:text-white" />
                                        </div>

                                        <!-- KRA PIN -->
                                        <div class="space-y-1">
                                            <label asp-for="KRAPIN" class="block text-sm font-semibold text-gray-700 dark:text-gray-300"></label>
                                            <input asp-for="KRAPIN"
                                                   class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none dark:text-white" />
                                        </div>

                                        <!-- Passport -->
                                        <div class="space-y-1">
                                            <label asp-for="PassportNo"
                                                   class="block text-sm font-semibold text-gray-700 dark:text-gray-300"></label>
                                            <input asp-for="PassportNo"
                                                   class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none dark:text-white" />
                                        </div>

                                        <!-- Employment Terms -->
                                        <div class="space-y-1">
                                            <label asp-for="EmploymentTermsId"
                                                   class="block text-sm font-semibold text-gray-700 dark:text-gray-300"></label>
                                            <select asp-for="EmploymentTermsId"
                                                    class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none dark:text-white"
                                                    asp-items="@(ViewData["EmploymentTermsId"] as SelectList)">
                                                <option value="">-- Select Employment Terms --</option>
                                            </select>
                                        </div>
                                        <!-- Disability Section -->
                                        <div class="md:col-span-2 flex items-center gap-2 border-b border-gray-100 dark:border-gray-700 pb-2 mt-4">
                                            <i class="bi bi-universal-access text-orange-500"></i>
                                            <h3 class="text-sm font-bold uppercase tracking-wider text-gray-400">
                                                Disability Information
                                            </h3>
                                        </div>

                                        <!-- Disability Dropdown -->
                                        <div class="space-y-1">
                                            <label asp-for="DisabilityId" class="block text-sm font-semibold text-gray-700 dark:text-gray-300">
                                                Disability Type
                                            </label>

                                            <select asp-for="DisabilityId" asp-items="@(ViewData["DisabilityId"] as SelectList)"
                                                    class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none dark:text-white">

                                                <option value="">-- Select Disability --</option>

                                            </select>

                                            <span asp-validation-for="DisabilityId" class="text-xs text-red-500"></span>
                                        </div>

                                        <!-- Disability Certificate Upload -->
                                        <div class="space-y-1">
                                            <label asp-for="DisabilityCertificate"
                                                   class="block text-sm font-semibold text-gray-700 dark:text-gray-300">
                                                Disability Certificate
                                            </label>

                                            <input asp-for="DisabilityCertificate"
                                                   class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none dark:text-white"
                                                   placeholder="Enter certificate number or reference" />

                                            <span asp-validation-for="DisabilityCertificate" class="text-xs text-red-500"></span>
                                        </div>

                                        <!-- Action Buttons -->
                                        <div
                                            class="mt-10 flex items-center justify-end space-x-4 border-t border-gray-100 dark:border-gray-700 pt-6 md:col-span-2">
                                            <a asp-action="Index"
                                                   class="px-6 py-2.5 text-sm font-semibold text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700 rounded-lg transition-colors">
                                                Cancel
                                            </a>
                                            <button type="submit"
                                                    class="inline-flex items-center px-8 py-2.5 bg-blue-600 hover:bg-blue-700 text-white text-sm font-bold rounded-lg shadow-md transition-all hover:shadow-lg transform hover:-translate-y-0.5">
                                                <i class="bi bi-check2-circle mr-2"></i>
                                                Save Employee
                                            </button>
                                        </div>
                                    </div>
                                </form>
                            </div>

                            @section Scripts {
                                @await Html.PartialAsync("_ValidationScriptsPartial")
                            }
@model EmployeesManagement.ViewModels.UserViewModel

@{
    ViewData["Title"] = "Create User";
}

<!-- Header -->
<div class="flex items-center justify-between mb-4">
    <div>
        <h1 class="text-2xl font-extrabold text-gray-900 dark:text-white tracking-tight">
            Create User
        </h1>
        <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5 flex items-center">
            <i class="bi bi-person-plus mr-1.5 text-indigo-500"></i>
            Add a new user to the system.
        </p>
    </div>

    <a asp-action="Index"
           class="hidden sm:inline-flex items-center text-xs font-semibold text-indigo-600 dark:text-indigo-400 hover:text-indigo-500 transition-colors group">
        <i class="bi bi-arrow-left mr-1.5 transition-transform group-hover:-translate-x-1"></i>
        Back to List
    </a>
</div>

<!-- Main Card -->
<div
    class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-xl shadow-lg overflow-hidden min-h-[500px]">

    <form asp-action="Create" method="post">

        <!-- Validation -->
        <div asp-validation-summary="ModelOnly"
             class="px-6 py-2 bg-rose-50 dark:bg-rose-900/20 text-rose-600 dark:text-rose-400 text-xs border-b border-rose-100 dark:border-rose-900/30">
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12">

            <!-- Left Side -->
            <div class="lg:col-span-7 p-8 border-b lg:border-b-0 lg:border-r border-gray-100 dark:border-gray-800">

                <div class="flex items-center mb-5">
                    <span
                        class="flex items-center justify-center w-6 h-6 rounded-full bg-indigo-100 dark:bg-indigo-900/40 text-indigo-600 dark:text-indigo-400 mr-2">
                        <i class="bi bi-person text-[10px]"></i>
                    </span>
                    <h3 class="text-[11px] font-bold uppercase tracking-widest text-gray-500 dark:text-gray-400">
                        User Information
                    </h3>
                </div>

                <div class="grid grid-cols-2 gap-5">

                    <!-- Username -->
                    <div class="col-span-2 space-y-1">
                        <label asp-for="UserName" class="text-xs font-bold text-gray-700 dark:text-gray-300 ml-1">
                            Username
                        </label>
                        <input asp-for="UserName"
                               class="w-full px-3 py-2 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-indigo-500 text-sm text-gray-900 dark:text-white shadow-sm"
                               placeholder="Enter username" />
                        <span asp-validation-for="UserName" class="text-rose-500 text-xs"></span>
                    </div>


                    <!-- First Name -->
                    <div class="space-y-1">
                        <label asp-for="FirstName"
                               class="text-xs font-bold text-gray-700 dark:text-gray-300 ml-1"></label>
                        <input asp-for="FirstName"
                               class="w-full px-3 py-2 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-indigo-500 text-sm text-gray-900 dark:text-white shadow-sm"
                               placeholder="Enter first name" />
                        <span asp-validation-for="FirstName" class="text-rose-500 text-xs"></span>
                    </div>

                    <!-- Middle Name -->
                    <div class="space-y-1">
                        <label asp-for="MiddleName"
                               class="text-xs font-bold text-gray-700 dark:text-gray-300 ml-1"></label>
                        <input asp-for="MiddleName"
                               class="w-full px-3 py-2 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-indigo-500 text-sm text-gray-900 dark:text-white shadow-sm"
                               placeholder="Enter middle name" />
                        <span asp-validation-for="MiddleName" class="text-rose-500 text-xs"></span>
                    </div>

                    <!-- Last Name -->
                    <div class="col-span-2 space-y-1">
                        <label asp-for="LastName"
                               class="text-xs font-bold text-gray-700 dark:text-gray-300 ml-1"></label>
                        <input asp-for="LastName"
                               class="w-full px-3 py-2 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-indigo-500 text-sm text-gray-900 dark:text-white shadow-sm"
                               placeholder="Enter last name" />
                        <span asp-validation-for="LastName" class="text-rose-500 text-xs"></span>
                    </div>

                    <!-- Email -->
                    <div class="col-span-2 space-y-1">
                        <label asp-for="Email" class="text-xs font-bold text-gray-700 dark:text-gray-300 ml-1"></label>
                        <input asp-for="Email" type="email"
                               class="w-full px-3 py-2 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-indigo-500 text-sm text-gray-900 dark:text-white shadow-sm"
                               placeholder="Enter email address" />
                        <span asp-validation-for="Email" class="text-rose-500 text-xs"></span>
                    </div>

                    <!-- Phone Number -->
                    <div class="col-span-2 space-y-1">
                        <label asp-for="PhoneNumber"
                               class="text-xs font-bold text-gray-700 dark:text-gray-300 ml-1"></label>
                        <input asp-for="PhoneNumber"
                               class="w-full px-3 py-2 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-indigo-500 text-sm text-gray-900 dark:text-white shadow-sm"
                               placeholder="Enter phone number" />
                        <span asp-validation-for="PhoneNumber" class="text-rose-500 text-xs"></span>
                    </div>

                    <!-- National ID -->
                    <div class="col-span-2 space-y-1">
                        <label asp-for="NationalId"
                               class="text-xs font-bold text-gray-700 dark:text-gray-300 ml-1"></label>
                        <input asp-for="NationalId"
                               class="w-full px-3 py-2 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-indigo-500 text-sm text-gray-900 dark:text-white shadow-sm"
                               placeholder="Enter national ID" />
                        <span asp-validation-for="NationalId" class="text-rose-500 text-xs"></span>
                    </div>

                    <!-- Role -->
                    <div class="col-span-2 space-y-1">
                        <label asp-for="RoleId" class="text-xs font-bold text-gray-700 dark:text-gray-300 ml-1">
                            Role
                        </label>

                        <select asp-for="RoleId" asp-items="ViewBag.RoleId"
                                class="w-full px-3 py-2 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-indigo-500 text-sm text-gray-900 dark:text-white shadow-sm">
                            <option value="">-- Select Role --</option>
                        </select>

                        <span asp-validation-for="RoleId" class="text-rose-500 text-xs"></span>
                    </div>

                    <!-- Password -->
                    <div class="col-span-2 space-y-1">
                        <label asp-for="Password"
                               class="text-xs font-bold text-gray-700 dark:text-gray-300 ml-1"></label>
                        <input asp-for="Password" type="password"
                               class="w-full px-3 py-2 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-indigo-500 text-sm text-gray-900 dark:text-white shadow-sm"
                               placeholder="Enter password" />
                        <span asp-validation-for="Password" class="text-rose-500 text-xs"></span>
                    </div>

                </div>
            </div>

            <!-- Right Side -->
            <div class="lg:col-span-5 p-8 bg-gray-50/30 dark:bg-gray-800/20">

                <div class="flex items-center mb-5">
                    <span
                        class="flex items-center justify-center w-6 h-6 rounded-full bg-amber-100 dark:bg-amber-900/40 text-amber-600 dark:text-amber-400 mr-2">
                        <i class="bi bi-shield-lock text-[10px]"></i>
                    </span>

                    <h3 class="text-[11px] font-bold uppercase tracking-widest text-gray-500 dark:text-gray-400">
                        Security Tips
                    </h3>
                </div>

                <div class="text-xs text-gray-500 dark:text-gray-400 space-y-3">
                    <p>• Use a strong password with letters and numbers.</p>
                    <p>• Avoid sharing credentials.</p>
                    <p>• Ensure email is valid for notifications.</p>
                </div>

            </div>

        </div>

        <!-- Footer -->
        <div
            class="flex items-center justify-between px-6 py-4 border-t border-gray-100 dark:border-gray-800 bg-gray-50 dark:bg-gray-800/50">

            <p class="hidden sm:block text-[9px] text-gray-400 uppercase font-black tracking-widest">
                System Access Required
            </p>

            <div class="flex items-center space-x-3 w-full sm:w-auto">

                <a asp-action="Index"
                       class="flex-1 sm:flex-none text-center px-4 py-2 text-xs font-bold text-gray-600 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700 rounded-lg transition-all">
                    Cancel
                </a>

                <button type="submit"
                        class="flex-1 sm:flex-none px-6 py-2 text-xs font-bold text-white bg-indigo-600 rounded-lg shadow-md hover:bg-indigo-700 hover:-translate-y-0.5 active:translate-y-0 transition-all">
                    Create User
                </button>

            </div>

        </div>

    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
@model IEnumerable<EmployeesManagement.Models.CompanyInformation>

@{
    ViewData["Title"] = "Companies";
}

<!-- Page Header -->
<div class="flex justify-between items-center mb-4">
    <h2 class="text-lg font-semibold text-gray-800 dark:text-white">
        Companies
    </h2>

    <a asp-action="Create"
       class="inline-flex items-center px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg shadow">
        <i class="bi bi-plus-lg mr-2"></i>
        Add Company
    </a>
</div>

<!-- Table -->
<div class="bg-white dark:bg-gray-800 rounded-2xl shadow border overflow-hidden">

    <div class="overflow-x-auto h-[500px] overflow-y-auto">
        <table class="w-full text-left">

            <!-- Header -->
            <thead>
                <tr class="bg-gray-50 dark:bg-gray-900 border-b">
                    <th class="px-6 py-4 text-xs font-bold uppercase">Name</th>
                    <th class="px-6 py-4 text-xs font-bold uppercase">Address</th>
                    <th class="px-6 py-4 text-xs font-bold uppercase">Phone</th>
                    <th class="px-6 py-4 text-xs font-bold uppercase">KRA PIN</th>
                    <th class="px-6 py-4 text-xs font-bold uppercase">City</th>
                    <th class="px-6 py-4 text-xs font-bold uppercase">Country</th>
                    <th class="px-6 py-4 text-xs font-bold uppercase text-right">Actions</th>
                </tr>
            </thead>

            <!-- Body -->
            <tbody class="divide-y dark:divide-gray-700">
                @foreach (var item in Model)
                {
                    <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/30 transition">

                        <td class="px-6 py-4 text-sm">@item.Name</td>
                        <td class="px-6 py-4 text-sm">@item.Address</td>
                        <td class="px-6 py-4 text-sm">@item.PhoneNo</td>
                        <td class="px-6 py-4 text-sm">@item.KRAPIN</td>
                        <td class="px-6 py-4 text-sm">@item.City?.Name</td>
                        <td class="px-6 py-4 text-sm">@item.Country?.Name</td>

                        <!-- Actions -->
                        <td class="px-6 py-4 text-right">
                            <div class="inline-flex rounded-lg border">

                                <a asp-action="Edit" asp-route-id="@item.Id"
                                   class="px-3 py-1.5 text-xs hover:bg-gray-100 border-r rounded-l-lg">
                                    <i class="bi bi-pencil"></i>
                                </a>

                                <a asp-action="Details" asp-route-id="@item.Id"
                                   class="px-3 py-1.5 text-xs hover:bg-gray-100 border-r">
                                    <i class="bi bi-eye"></i>
                                </a>

                                <a asp-action="Delete" asp-route-id="@item.Id"
                                   class="px-3 py-1.5 text-xs text-red-600 hover:bg-red-50 rounded-r-lg">
                                    <i class="bi bi-trash"></i>
                                </a>

                            </div>
                        </td>
                    </tr>
                }

                <!-- Empty State -->
                @if (Model == null || !Model.Any())
                {
                    <tr>
                        <td colspan="7" class="px-6 py-16 text-center text-gray-500">
                            <div class="flex flex-col items-center">
                                <i class="bi bi-building text-4xl mb-3"></i>
                                <p>No Companies Found</p>
                                <a asp-action="Create" class="mt-3 px-3 py-1.5 text-xs bg-blue-600 text-white rounded">
                                    Add Company
                                </a>
                            </div>
                        </td>
                    </tr>
                }

            </tbody>

        </table>
    </div>

    <!-- Footer -->
    <div class="px-6 py-3 bg-gray-50 dark:bg-gray-900 text-xs text-gray-500 font-bold">
        Total: @Model.Count()
    </div>

</div>
@model EmployeesManagement.ViewModels.HolidayViewModel

@{
    ViewData["Title"] = "Holidays";
}

<!-- Page Header -->
<div class="flex justify-between items-center mb-4">
    <h2 class="text-lg font-semibold text-gray-800 dark:text-white">
        Holidays
    </h2>

    <a asp-action="Create"
       class="inline-flex items-center px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg shadow transition-colors">
        <i class="bi bi-plus-lg mr-2"></i>
        Add Holiday
    </a>
</div>

<!-- Search Form -->
<form method="get" asp-action="Index" class="mb-4">
    <div class="grid grid-cols-1 md:grid-cols-5 gap-3">

        <!-- Title -->
        <input asp-for="Title" placeholder="Title"
               class="px-3 py-2 border rounded-lg text-sm dark:bg-gray-800 dark:border-gray-600 dark:text-white" />

        <!-- Description -->
        <input asp-for="Description" placeholder="Description"
               class="px-3 py-2 border rounded-lg text-sm dark:bg-gray-800 dark:border-gray-600 dark:text-white" />

        <!-- Start Date -->
        <input asp-for="StartDate" type="date" placeholder="Start Date"
               class="px-3 py-2 border rounded-lg text-sm dark:bg-gray-800 dark:border-gray-600 dark:text-white" />

        <!-- End Date -->
        <input asp-for="EndDate" type="date" placeholder="End Date"
               class="px-3 py-2 border rounded-lg text-sm dark:bg-gray-800 dark:border-gray-600 dark:text-white" />

        <!-- Buttons -->
        <div class="flex space-x-2">
            <button type="submit" class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm rounded-lg">
                Search
            </button>

            <a asp-action="Index" class="px-4 py-2 bg-gray-300 hover:bg-gray-400 text-sm rounded-lg">
                Clear
            </a>
        </div>

    </div>
</form>

<!-- Table Container -->
<div
    class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden">

    <!-- Scrollable Table -->
    <div class="overflow-x-auto h-[500px] overflow-y-auto">
        <table class="w-full text-left border-collapse">

            <thead>
                <tr class="bg-gray-50 dark:bg-gray-900/50 border-b border-gray-100 dark:border-gray-700">
                    <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400">
                        Title</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400">
                            Start Date</th>
                            <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400">
                                End Date</th>
                                <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400">
                                    Description</th>
                                    <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400">
                                        Created By</th>
                                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400">
                                            Created On</th>
                                            <th
                                                class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 text-right">
                                                Actions</th>
                                            </tr>
                                        </thead>

                                        <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
                                            @foreach (var item in Model.Holidays)
                                            {
                                                <tr class="hover:bg-gray-50/50 dark:hover:bg-gray-700/30 transition-colors duration-150">
                                                    <td class="px-6 py-4 text-sm text-gray-900 dark:text-gray-200">@item.Title</td>
                                                    <td class="px-6 py-4 text-sm text-gray-900 dark:text-gray-200">@item.StartDate.ToString("MMM dd, yyyy")</td>
                                                    <td class="px-6 py-4 text-sm text-gray-900 dark:text-gray-200">@item.EndDate.ToString("MMM dd, yyyy")</td>
                                                    <td class="px-6 py-4 text-sm text-gray-900 dark:text-gray-200">@item.Description</td>
                                                    <td class="px-6 py-4 text-sm text-gray-900 dark:text-gray-200">@item.CreatedById</td>
                                                    <td class="px-6 py-4 text-sm text-gray-900 dark:text-gray-200">@item.CreatedOn.ToString("MMM dd, yyyy")</td>

                                                    <!-- Actions -->
                                                    <td class="px-6 py-4 text-right space-x-2">
                                                        <div class="inline-flex rounded-lg shadow-sm border border-gray-200 dark:border-gray-600">
                                                            <a asp-action="Edit" asp-route-id="@item.id"
                                                               class="px-3 py-1.5 text-xs font-medium text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 border-r border-gray-200 dark:border-gray-600 rounded-l-lg">
                                                                <i class="bi bi-pencil"></i>
                                                            </a>

                                                            <a asp-action="Details" asp-route-id="@item.id"
                                                               class="px-3 py-1.5 text-xs font-medium text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 border-r border-gray-200 dark:border-gray-600">
                                                                <i class="bi bi-eye"></i>
                                                            </a>

                                                            <a asp-action="Delete" asp-route-id="@item.id"
                                                               class="px-3 py-1.5 text-xs font-medium text-red-600 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-r-lg">
                                                                <i class="bi bi-trash"></i>
                                                            </a>
                                                        </div>
                                                    </td>
                                                </tr>
                                            }

                                            <!-- Empty Data -->
                                            @if (Model.Holidays == null || !Model.Holidays.Any())
                                            {
                                                <tr>
                                                    <td colspan="7" class="px-6 py-16 text-center text-gray-500 dark:text-gray-400">
                                                        <div class="flex flex-col items-center">
                                                            <i class="bi bi-calendar-x text-4xl mb-3"></i>
                                                            <p class="text-sm mb-3">No Holidays Found</p>
                                                            <a asp-action="Create"
                                                               class="px-3 py-1.5 text-xs bg-blue-600 text-white rounded-md hover:bg-blue-700">
                                                                Add First Holiday
                                                            </a>
                                                        </div>
                                                    </td>
                                                </tr>
                                            }

                                        </tbody>

                                    </table>

                                </div>

                                <!-- Footer -->
                                <div
                                    class="px-6 py-4 bg-gray-50 dark:bg-gray-900/50 border-t border-gray-100 dark:border-gray-700 flex items-center justify-between text-xs text-gray-500 uppercase font-bold tracking-widest">
                                    <span>Showing @Model.Holidays.Count() Holidays</span>
                                    <div class="flex space-x-1">
                                        <button
                                        class="px-2 py-1 rounded border border-gray-200 dark:border-gray-600 hover:bg-white dark:hover:bg-gray-800">Prev</button>
                                        <button
                                        class="px-2 py-1 rounded border border-gray-200 dark:border-gray-600 hover:bg-white dark:hover:bg-gray-800">Next</button>
                                    </div>
                                </div>
                            </div>
@model EmployeesManagement.Models.LeavePeriod

@{
    ViewData["Title"] = "Create Leave Period";
}

<div
    class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden">

    <form asp-action="Create" method="post" class="p-6 md:p-8">

        <!-- Validation -->
        <div asp-validation-summary="ModelOnly"
             class="mb-6 p-4 bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 text-sm rounded-lg border border-red-100 dark:border-red-800">
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-6">

            <!-- Section -->
            <div class="md:col-span-2 flex items-center gap-2 border-b border-gray-100 dark:border-gray-700 pb-2">
                <i class="bi bi-calendar-range text-blue-500"></i>
                <h3 class="text-sm font-bold uppercase tracking-wider text-gray-400">
                    Leave Period Details
                </h3>
            </div>

            <!-- Name -->
            <div class="space-y-1">
                <label asp-for="Name" class="block text-sm font-semibold text-gray-700 dark:text-gray-300"></label>
                <input asp-for="Name"
                       class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none dark:text-white"
                       placeholder="e.g. 2026 Annual Leave" />
                <span asp-validation-for="Name" class="text-xs text-red-500"></span>
            </div>

            <!-- Description -->
            <div class="space-y-1">
                <label asp-for="Description"
                       class="block text-sm font-semibold text-gray-700 dark:text-gray-300"></label>
                <input asp-for="Description"
                       class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none dark:text-white"
                       placeholder="Optional description" />
                <span asp-validation-for="Description" class="text-xs text-red-500"></span>
            </div>

            <!-- Start Date -->
            <div class="space-y-1">
                <label asp-for="StartDate" class="block text-sm font-semibold text-gray-700 dark:text-gray-300"></label>
                <input asp-for="StartDate" type="date"
                       class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none dark:text-white" />
                <span asp-validation-for="StartDate" class="text-xs text-red-500"></span>
            </div>

            <!-- End Date -->
            <div class="space-y-1">
                <label asp-for="EndDate" class="block text-sm font-semibold text-gray-700 dark:text-gray-300"></label>
                <input asp-for="EndDate" type="date"
                       class="w-full px-4 py-2.5 bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none dark:text-white" />
                <span asp-validation-for="EndDate" class="text-xs text-red-500"></span>
            </div>

            <!-- Closed -->
            <div class="flex items-center space-x-2">
                <input asp-for="Closed" type="checkbox"
                       class="h-4 w-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" />
                <label asp-for="Closed" class="text-sm text-gray-700 dark:text-gray-300"></label>
            </div>

            <!-- Locked -->
            <div class="flex items-center space-x-2">
                <input asp-for="Locked" type="checkbox"
                       class="h-4 w-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" />
                <label asp-for="Locked" class="text-sm text-gray-700 dark:text-gray-300"></label>
            </div>

            <!-- Buttons -->
            <div
                class="mt-10 flex justify-end space-x-4 border-t border-gray-100 dark:border-gray-700 pt-6 md:col-span-2">

                <a asp-action="Index"
                       class="px-6 py-2.5 text-sm font-semibold text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700 rounded-lg">
                    Cancel
                </a>

                <button type="submit"
                        class="inline-flex items-center px-8 py-2.5 bg-blue-600 hover:bg-blue-700 text-white text-sm font-bold rounded-lg shadow-md">
                    <i class="bi bi-check2-circle mr-2"></i>
                    Create Leave Period
                </button>

            </div>

        </div>
    </form>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
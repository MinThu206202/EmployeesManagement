@model IEnumerable<EmployeesManagement.Models.Audit>

@{
    ViewData["Title"] = "Audit Logs";
}

<div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4">
    <div>
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Audit Logs</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400">Track all system changes and user activities.</p>
    </div>
    <div class="flex gap-2">
    </div>
</div>

<div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead class="bg-gray-50 dark:bg-gray-900/50 border-b border-gray-200 dark:border-gray-700">
                <tr>
                    <th class="w-10 px-6 py-4"></th>
                    <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-gray-500">User</th>
                    <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-gray-500">Action</th>
                    <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-gray-500">Resource</th>
                    <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-gray-500">Timestamp</th>
                </tr>
            </thead>

            <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
                @foreach (var item in Model)
                {
                    var rowId = "row_" + item.id;
                    
                    <tr class="group hover:bg-blue-50/30 dark:hover:bg-blue-900/10 transition-colors duration-150 cursor-pointer"
                        onclick="toggleRow('@rowId')">
                        
                        <td class="px-6 py-4 text-center">
                            <button class="text-gray-400 group-hover:text-blue-500 transition-transform duration-200"
                                    id="btn_@rowId">
                                <i class="bi bi-chevron-right transition-transform" id="icon_@rowId"></i>
                            </button>
                        </td>

                        <td class="px-6 py-4 font-medium text-gray-700 dark:text-gray-200">
                            <div class="flex items-center gap-2">
                                <div
                                    class="w-7 h-7 rounded-full bg-gray-200 dark:bg-gray-700 flex items-center justify-center text-[10px]">
                                    @(item.UserId?.Substring(0, 1).ToUpper() ?? "?")
                                </div>
                                @(item.UserId ?? "System")
                            </div>
                        </td>

                        <td class="px-6 py-4">
                            @{
                                var badgeClass = item.AuditType switch
                                {
                                    "Create" => "bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400",
                                    "Update" => "bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400",
                                    "Delete" => "bg-rose-100 text-rose-700 dark:bg-rose-900/30 dark:text-rose-400",
                                    _ => "bg-slate-100 text-slate-700 dark:bg-slate-800 dark:text-slate-400"
                                };
                            }
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-md text-xs font-medium @badgeClass">
                                @item.AuditType
                            </span>
                        </td>

                        <td class="px-6 py-4 text-gray-600 dark:text-gray-400">
                            <code class="text-xs bg-gray-100 dark:bg-gray-700 px-1.5 py-0.5 rounded">@item.TableName</code>
                        </td>

                        <td class="px-6 py-4 text-gray-500 dark:text-gray-400 text-sm whitespace-nowrap">
                            @item.DateTime.ToString("MMM dd, yyyy")
                            <span class="text-xs opacity-60">@item.DateTime.ToString("HH:mm")</span>
                        </td>
                    </tr>

                    <tr id="@rowId" class="hidden bg-gray-50/50 dark:bg-gray-900/40 border-l-4 border-blue-500">
                        <td colspan="5" class="px-8 py-6">
                            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                                
                                <div class="space-y-3">
                                    <h4 class="text-xs font-bold uppercase text-gray-400 tracking-widest">Metadata</h4>
                                    <div
                                        class="flex justify-between text-sm py-1 border-b border-gray-100 dark:border-gray-800">
                                        <span class="text-gray-500">Primary Key</span>
                                        <span class="font-mono text-blue-600">@item.Primarykey</span>
                                    </div>
                                    <div
                                        class="flex justify-between text-sm py-1 border-b border-gray-100 dark:border-gray-800">
                                        <span class="text-gray-500">Changed Columns</span>
                                        <span class="text-gray-700 dark:text-gray-300">@item.AffectedColumns</span>
                                    </div>
                                </div>

                                <div class="space-y-4">
                                    <h4 class="text-xs font-bold uppercase text-gray-400 tracking-widest">Data Change</h4>
                                    <div class="grid grid-cols-1 gap-2">
                                        <div
                                            class="p-3 bg-red-50 dark:bg-red-900/10 rounded-lg border border-red-100 dark:border-red-900/30">
                                            <p class="text-[10px] uppercase font-bold text-red-400 mb-1">Before</p>
                                            <pre
                                            class="text-xs text-red-700 dark:text-red-300 whitespace-pre-wrap font-mono">@(item.OldValues ?? "Empty")</pre>
                                        </div>
                                        <div
                                            class="p-3 bg-emerald-50 dark:bg-emerald-900/10 rounded-lg border border-emerald-100 dark:border-emerald-900/30">
                                            <p class="text-[10px] uppercase font-bold text-emerald-400 mb-1">After</p>
                                            <pre
                                            class="text-xs text-emerald-700 dark:text-emerald-300 whitespace-pre-wrap font-mono">@(item.NewValues ?? "Empty")</pre>
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    function toggleRow(id) {
        const row = document.getElementById(id);
        const icon = document.getElementById('icon_' + id);
        
        row.classList.toggle("hidden");
        
        // Rotate icon logic
        if (row.classList.contains("hidden")) {
            icon.style.transform = "rotate(0deg)";
        } else {
            icon.style.transform = "rotate(90deg)";
        }
    }
</script>
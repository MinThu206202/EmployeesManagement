@model IEnumerable<EmployeesManagement.Models.SystemProfile>

@{
    ViewData["Title"] = "System Profiles";
}

<!-- Page Header -->
<div class="flex justify-between items-center mb-4">
    <h2 class="text-lg font-semibold text-gray-800 dark:text-white">
        System Profiles
    </h2>

    <a asp-action="Create"
           class="inline-flex items-center px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg shadow transition-colors">
        <i class="bi bi-plus-lg mr-2"></i>
        Add Profile
    </a>
</div>

<!-- Table Container -->
<div
    class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden">
    <div class="overflow-x-auto h-[500px] overflow-y-auto">
        <table class="w-full text-left border-collapse">

            <!-- Table Header -->
            <thead>
                <tr class="bg-gray-50 dark:bg-gray-900/50 border-b border-gray-100 dark:border-gray-700">
                    <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400">No
                    </th>
                    <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400">
                        Name</th>
                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400">
                            Profile</th>
                            <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400">
                                Order</th>
                                <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400">
                                    Created By</th>
                                    <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400">
                                        Created On</th>
                                        <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400">
                                            Modified By</th>
                                            <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400">
                                                Modified On</th>
                                                <th
                                                    class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 text-right">
                                                    Actions</th>
                                                </tr>
                                            </thead>

                                            <!-- Table Body -->
                                            <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
                                                @{
                                                    int count = 1;
                                                }

                                                @foreach (var item in Model)
                                                {
                                                    <tr class="hover:bg-gray-50/50 dark:hover:bg-gray-700/30 transition-colors duration-150">
                                                        <td class="px-6 py-4 text-sm text-gray-700 dark:text-gray-200">@count</td>
                                                        <td class="px-6 py-4 text-sm text-gray-700 dark:text-gray-200">@(!string.IsNullOrEmpty(item.Name) ?
                                                                                                                                                                                                            item.Name : "-")</td>
                                                            <td class="px-6 py-4 text-sm text-gray-700 dark:text-gray-200">@((item.Profile != null &&
                                                                                                                                                                                                                        !string.IsNullOrEmpty(item.Profile.Name)) ? item.Profile.Name : "-")</td>
                                                                <td class="px-6 py-4 text-sm text-gray-700 dark:text-gray-200">@((item.Order > 0) ?
                                                                                                                                                                                                                                    item.Order.ToString() : "-")</td>
                                                                    <td class="px-6 py-4 text-sm text-gray-700 dark:text-gray-200">
                                                                        @(!string.IsNullOrEmpty(item.CreatedById) ? item.CreatedById : "-")</td>
                                                                        <td class="px-6 py-4 text-sm text-gray-700 dark:text-gray-200">@((item.CreatedOn !=
                                                                                                                                                                                                                                                            DateTime.MinValue) ? item.CreatedOn.ToString("yyyy-MM-dd") : "-")</td>
                                                                            <td class="px-6 py-4 text-sm text-gray-700 dark:text-gray-200">
                                                                                @(!string.IsNullOrEmpty(item.ModifiedById) ? item.ModifiedById : "-")</td>
                                                                                <td class="px-6 py-4 text-sm text-gray-700 dark:text-gray-200">@((item.ModifiedOn != null &&
                                                                                                                                                                                                                                                                                    item.ModifiedOn != DateTime.MinValue) ? item.ModifiedOn.ToString("yyyy-MM-dd") : "-")</td>
                                                                                    <td class="px-6 py-4 text-right">
                                                                                        <div class="inline-flex rounded-lg shadow-sm border border-gray-200 dark:border-gray-600">
                                                                                            <a asp-action="Edit" asp-route-id="@item.Id"
                                                                                                   class="px-3 py-1.5 text-xs font-medium text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 rounded-l-lg border-r border-gray-200 dark:border-gray-600">
                                                                                                <i class="bi bi-pencil"></i>
                                                                                            </a>
                                                                                            <a asp-action="Details" asp-route-id="@item.Id"
                                                                                                   class="px-3 py-1.5 text-xs font-medium text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 border-r border-gray-200 dark:border-gray-600">
                                                                                                <i class="bi bi-eye"></i>
                                                                                            </a>
                                                                                            <a asp-action="Delete" asp-route-id="@item.Id"
                                                                                                   class="px-3 py-1.5 text-xs font-medium text-red-600 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-r-lg">
                                                                                                <i class="bi bi-trash"></i>
                                                                                            </a>
                                                                                        </div>
                                                                                    </td>
                                                                                </tr>
                                                                                count++;
                                                                            }

                                                                            <!-- Empty State -->
                                                                            @if (!Model.Any())
                                                                            {
                                                                                <tr>
                                                                                    <td colspan="9" class="px-6 py-16 text-center text-gray-500 dark:text-gray-400">
                                                                                        <div class="flex flex-col items-center">
                                                                                            <i class="bi bi-file-earmark text-4xl mb-3"></i>
                                                                                            <p class="text-sm mb-3">No System Profiles Found</p>
                                                                                            <a asp-action="Create"
                                                                                                   class="px-3 py-1.5 text-xs bg-blue-600 text-white rounded-md hover:bg-blue-700">
                                                                                                Add First Profile
                                                                                            </a>
                                                                                        </div>
                                                                                    </td>
                                                                                </tr>
                                                                            }
                                                                        </tbody>

                                                                    </table>
                                                                </div>

                                                                <!-- Footer -->
                                                                <div
                                                                    class="px-6 py-4 bg-gray-50 dark:bg-gray-900/50 border-t border-gray-100 dark:border-gray-700 flex items-center justify-between text-xs text-gray-500 uppercase font-bold tracking-widest">
                                                                    <span>Showing @Model.Count() Profiles</span>
                                                                    <div class="flex space-x-1">
                                                                        <button
                                                                        class="px-2 py-1 rounded border border-gray-200 dark:border-gray-600 hover:bg-white dark:hover:bg-gray-800">Prev</button>
                                                                        <button
                                                                        class="px-2 py-1 rounded border border-gray-200 dark:border-gray-600 hover:bg-white dark:hover:bg-gray-800">Next</button>
                                                                    </div>
                                                                </div>
                                                            </div>
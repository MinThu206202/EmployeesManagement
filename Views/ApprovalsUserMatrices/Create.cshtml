@model EmployeesManagement.Models.ApprovalsUserMatrix

@{
    ViewData["Title"] = "Create Matrix";
}

<div
    class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden">

    <form asp-action="Create" method="post" class="p-6 md:p-8">

        <!-- Validation -->
        <div asp-validation-summary="ModelOnly" class="mb-6 p-4 bg-red-50 text-red-600 text-sm rounded-lg border">
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

            <!-- Section Header -->
            <div class="md:col-span-2 flex items-center gap-2 border-b pb-2">
                <i class="bi bi-diagram-3 text-blue-500"></i>
                <h3 class="text-sm font-bold uppercase text-gray-400">
                    Approvals User Matrix
                </h3>
            </div>

            <!-- User -->
            <div class="space-y-1">
                <label asp-for="UserId" class="text-sm font-semibold">User</label>
                <select asp-for="UserId" asp-items="ViewBag.UserId"
                        class="w-full px-4 py-2.5 border rounded-lg focus:ring-2 focus:ring-blue-500">
                    <option value="">-- Select User --</option>
                </select>
                <span asp-validation-for="UserId" class="text-xs text-red-500"></span>
            </div>

            <!-- Document Type -->
            <div class="space-y-1">
                <label asp-for="DocumentTypeId" class="text-sm font-semibold">Document Type</label>
                <select asp-for="DocumentTypeId" asp-items="ViewBag.DocumentTypeId"
                        class="w-full px-4 py-2.5 border rounded-lg focus:ring-2 focus:ring-blue-500">
                    <option value="">-- Select Document Type --</option>
                </select>
                <span asp-validation-for="DocumentTypeId" class="text-xs text-red-500"></span>
            </div>

            <!-- Workflow Group -->
            <div class="space-y-1 md:col-span-2">
                <label asp-for="WorkFlowUserGroupId" class="text-sm font-semibold">Workflow Group</label>
                <select asp-for="WorkFlowUserGroupId" asp-items="ViewBag.WorkFlowUserGroupId"
                        class="w-full px-4 py-2.5 border rounded-lg focus:ring-2 focus:ring-blue-500">
                    <option value="">-- Select Workflow Group --</option>
                </select>
                <span asp-validation-for="WorkFlowUserGroupId" class="text-xs text-red-500"></span>
            </div>

            <!-- Buttons -->
            <div class="md:col-span-2 flex justify-end gap-4 mt-6 border-t pt-6">
                <a asp-action="Index" class="px-6 py-2 text-sm text-gray-600 hover:bg-gray-100 rounded-lg">
                    Cancel
                </a>

                <button type="submit"
                        class="px-6 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold rounded-lg shadow">
                    <i class="bi bi-check2-circle mr-1"></i>
                    Save Matrix
                </button>
            </div>

        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
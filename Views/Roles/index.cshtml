@model IEnumerable<Microsoft.AspNetCore.Identity.IdentityRole>

@{
    ViewData["Title"] = "System Roles";
}

<!-- Page Header -->
<div class="flex justify-between items-center mb-4">

    <h2 class="text-lg font-semibold text-gray-800 dark:text-white">
        Roles
    </h2>

    <a asp-action="Create"
           class="inline-flex items-center px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg shadow transition-colors">

        <i class="bi bi-person-plus mr-2"></i>
        Add Role

    </a>

</div>

<!-- Table Container -->
<div
    class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden">

    <div class="overflow-x-auto h-[500px] overflow-y-auto">

        <table class="w-full text-left border-collapse">

            <!-- Table Header -->
            <thead>

                <tr class="bg-gray-50 dark:bg-gray-900/50 border-b border-gray-100 dark:border-gray-700">

                    <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400">
                        Role No
                    </th>
                    <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400">
                        Role Name
                    </th>
                    <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400">
                        Actions
                    </th>
                </tr>
            </thead>

            <tbody class="divide-y divide-gray-100 dark:divide-gray-700">



                @foreach (var item in Model)
                {

                    <tr class="hover:bg-gray-50/50 dark:hover:bg-gray-700/30 transition-colors duration-150">

                        <!-- Serial Number -->
                        <td class="px-6 py-4 text-sm text-gray-700 dark:text-gray-200">
                            @item.Id
                        </td>

                        <!-- Email -->
                        <td class="px-6 py-4">

                            <div class="text-sm font-medium text-gray-900 dark:text-white">
                                @item.Name
                            </div>

                        </td>
                        <!-- Actions -->
                        <td class="px-6 py-4 text-left">
                            <div class="inline-flex rounded-lg shadow-sm border border-gray-200 dark:border-gray-600">

                                <!-- Edit -->
                                <a asp-action="Edit" asp-route-id="@item.Id"
                                       class="flex items-center justify-center px-3 py-1.5 text-xs font-medium text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 rounded-l-lg border-r border-gray-200 dark:border-gray-600">
                                    <i class="bi bi-pencil"></i>
                                </a>

                                <!-- Details -->
                                <a asp-action="Details" asp-route-id="@item.Id"
                                       class="flex items-center justify-center px-3 py-1.5 text-xs font-medium text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 border-r border-gray-200 dark:border-gray-600">
                                    <i class="bi bi-eye"></i>
                                </a>

                                <!-- Delete -->
                                <a asp-action="Delete" asp-route-id="@item.Id"
                                       class="flex items-center justify-center px-3 py-1.5 text-xs font-medium text-red-600 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-r-lg">
                                    <i class="bi bi-trash"></i>
                                </a>

                            </div>
                        </td>

                    </tr>

                }

                <!-- Empty State -->
                @if (!Model.Any())
                {

                    <tr>

                        <td colspan="5" class="px-6 py-16 text-center text-gray-500 dark:text-gray-400">

                            <div class="flex flex-col items-center">

                                <i class="bi bi-people text-4xl mb-3"></i>

                                <p class="text-sm mb-3">
                                    No Rolea Found
                                </p>

                                <a asp-action="Create"
                                       class="px-3 py-1.5 text-xs bg-blue-600 text-white rounded-md hover:bg-blue-700">

                                    Add First Role

                                </a>

                            </div>

                        </td>

                    </tr>

                }

            </tbody>

        </table>

    </div>

    <!-- Footer -->
    <div
        class="px-6 py-4 bg-gray-50 dark:bg-gray-900/50 border-t border-gray-100 dark:border-gray-700 flex items-center justify-between text-xs text-gray-500 uppercase font-bold tracking-widest">

        <span>
            Showing @Model.Count() Users
        </span>

        <div class="flex space-x-1">

            <button
                class="px-2 py-1 rounded border border-gray-200 dark:border-gray-600 hover:bg-white dark:hover:bg-gray-800">
                Prev
            </button>

            <button
                class="px-2 py-1 rounded border border-gray-200 dark:border-gray-600 hover:bg-white dark:hover:bg-gray-800">
                Next
            </button>

        </div>

    </div>

</div>
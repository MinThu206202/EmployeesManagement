<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>HRConnect - Employee Management System</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
          rel="stylesheet" />
    <style>
        body {
        font-family: 'Inter', sans-serif;
        }

        /* Smooth Sidebar Transitions */
        .sidebar-transition {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        /* Custom Scrollbar */
        .scrollbar-hide::-webkit-scrollbar {
        display: none;
        }

        .scrollbar-hide {
        -ms-overflow-style: none;
        scrollbar-width: none;
        }

        @@media (max-width: 768px) {
        .sidebar-mobile-hidden {
        transform: translateX(-100%);
        }

        .sidebar-mobile-visible {
        transform: translateX(0);
        }
        }

        /* Submenu Animation & Styles */
        .submenu-container {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.3s ease-out, opacity 0.2s ease;
        opacity: 0;
        }

        .submenu-container.open {
        max-height: 500px;
        /* Large enough to fit content */
        opacity: 1;
        }

        /* Rotate Chevron */
        .chevron-icon {
        transition: transform 0.3s ease;
        }

        .chevron-rotate {
        transform: rotate(180deg);
        }

        /* Vertical line for nested feel */
        .submenu-line {
        position: absolute;
        left: 24px;
        top: 0;
        bottom: 0;
        width: 1px;
        background: rgba(255, 255, 255, 0.1);
        }
    </style>
</head>

<body class="bg-[#f8fafc] dark:bg-gray-950 text-slate-900 dark:text-slate-100 overflow-hidden">

    <!-- Mobile Overlay -->
    <div id="mobile-overlay" class="fixed inset-0 z-40 hidden md:hidden bg-black/50 backdrop-blur-sm transition-opacity"
         onclick="toggleSidebar()"></div>

    <div class="flex h-screen overflow-hidden">
        <!-- Sidebar -->
        <aside id="sidebar"
               class="sidebar-transition fixed inset-y-0 left-0 z-50 w-64 bg-[#0f172a] text-slate-300 flex-shrink-0 flex flex-col shadow-2xl md:relative sidebar-mobile-hidden md:translate-x-0">

            <!-- Sidebar Brand -->
            <div class="h-20 flex items-center px-6 bg-[#0f172a] border-b border-slate-800/50">
                <div
                    class="w-10 h-10 bg-indigo-600 rounded-xl flex items-center justify-center mr-3 shadow-lg shadow-indigo-500/20">
                    <i class="bi bi-person-gear text-white text-xl"></i>
                </div>
                <div class="sidebar-text">
                    <h1 class="text-lg font-bold text-white tracking-tight leading-none">HRConnect</h1>
                    <p class="text-[10px] text-slate-500 font-semibold uppercase tracking-wider mt-1">Management Pro</p>
                </div>
            </div>

            <!-- Sidebar Navigation -->
            <div class="flex-grow overflow-y-auto py-6 scrollbar-hide">
                <nav class="px-4 space-y-1.5">

                    <p
                        class="text-[11px] font-bold text-slate-500 uppercase px-3 py-2 mb-1 tracking-widest sidebar-text">
                        Analytics
                    </p>

                    <a href="#"
                       class="flex items-center px-4 py-3 rounded-xl bg-indigo-600/10 text-indigo-400 group transition-all">
                        <i class="bi bi-grid-1x2-fill mr-4 text-lg"></i>
                        <span class="sidebar-text font-medium">Dashboard</span>
                    </a>

                    <p
                        class="text-[11px] font-bold text-slate-500 uppercase px-3 py-2 mt-6 mb-1 tracking-widest sidebar-text">
                        Employee Hub
                    </p>

                    <!-- HR & Payroll Dropdown -->
                    <div class="relative">
                        <button onclick="toggleMenu('Payroll', this)"
                                class="flex items-center w-full px-4 py-3 text-slate-400 hover:text-white hover:bg-slate-800/50 rounded-xl transition-all">
                            <i class="bi bi-calendar-check-fill mr-4 text-lg"></i>
                            <span class="sidebar-text font-medium flex-grow text-left">HR & Payroll</span>
                            <i class="bi bi-chevron-down text-[10px] chevron-icon"></i>
                        </button>

                        <div id="Payroll" class="submenu-container relative">
                            <div class="submenu-line sidebar-text"></div>
                            <div class="pl-12 pr-4 py-1 space-y-1">
                                <a asp-action="index" asp-controller="Employees"
                                   class="block py-2 text-sm text-slate-400 hover:text-indigo-400 transition-colors">Employee
                                    List</a>
                                    <a asp-action="index" asp-controller="Holidays"
                                       class="block py-2 text-sm text-slate-400 hover:text-indigo-400 transition-colors">Holidays
                                    </a>
                                    <a asp-action="index" asp-controller="LeaveAdjustmentEntries"
                                       class="block py-2 text-sm text-slate-400 hover:text-indigo-400 transition-colors">LeaveAdjustmentEntry
                                    </a>
                                    <a asp-action="index" asp-controller="LeaveBalances"
                                       class="block py-2 text-sm text-slate-400 hover:text-indigo-400 transition-colors">LeaveBalance
                                    </a>
                                    <a asp-action="index" asp-controller="LeavePeriods"
                                       class="block py-2 text-sm text-slate-400 hover:text-indigo-400 transition-colors">Leave
                                        Period
                                    </a>
                                </div>
                            </div>
                        </div>

                        <!-- Leave Applications Dropdown -->
                        <div class="relative">
                            <button onclick="toggleMenu('leaveMenu', this)"
                                    class="flex items-center w-full px-4 py-3 text-slate-400 hover:text-white hover:bg-slate-800/50 rounded-xl transition-all">
                                <i class="bi bi-calendar-check-fill mr-4 text-lg"></i>
                                <span class="sidebar-text font-medium flex-grow text-left">Leave Applications</span>
                                <i class="bi bi-chevron-down text-[10px] chevron-icon"></i>
                            </button>

                            <div id="leaveMenu" class="submenu-container relative">
                                <div class="submenu-line sidebar-text"></div>
                                <div class="pl-12 pr-4 py-1 space-y-1">
                                    <a asp-action="index" asp-controller="LeaveTypes"
                                       class="block py-2 text-sm text-slate-400 hover:text-indigo-400 transition-colors">Leave
                                        Type</a>
                                        <a asp-action="index" asp-controller="LeaveApplications"
                                           class="block py-2 text-sm text-slate-400 hover:text-indigo-400 transition-colors">Leave
                                            Application</a>
                                            <a asp-action="ApproveLeaveApplications" asp-controller="LeaveApplications"
                                               class="block py-2 text-sm text-slate-400 hover:text-indigo-400 transition-colors">Approve
                                                Leave Applications</a>
                                                <a asp-action="RejectLeaveApplications" asp-controller="LeaveApplications"
                                                   class="block py-2 text-sm text-slate-400 hover:text-indigo-400 transition-colors">Reject
                                                    Leave Applications</a>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="relative">
                                            <button onclick="toggleMenu('systemSecurityMenu', this)"
                                                    class="flex items-center w-full px-4 py-3 text-slate-400 hover:text-white hover:bg-slate-800/50 rounded-xl transition-all">
                                                <i class="bi bi-calendar-check-fill mr-4 text-lg"></i>
                                                <span class="sidebar-text font-medium flex-grow text-left">System Security</span>
                                                <i class="bi bi-chevron-down text-[10px] chevron-icon"></i>
                                            </button>
                                            <div id="systemSecurityMenu" class="submenu-container relative">
                                                <div class="submenu-line sidebar-text"></div>
                                                <div class="pl-12 pr-4 py-1 space-y-1">
                                                    <a asp-action="index" asp-controller="Users"
                                                       class="block py-2 text-sm text-slate-400 hover:text-indigo-400 transition-colors">System
                                                        User</a>
                                                        <a asp-action="index" asp-controller="Roles"
                                                           class="block py-2 text-sm text-slate-400 hover:text-indigo-400 transition-colors">System
                                                            Role</a>
                                                            <a asp-action="index" asp-controller="SystemProfiles"
                                                               class="block py-2 text-sm text-slate-400 hover:text-indigo-400 transition-colors">System
                                                                Profile</a>
                                                                <a asp-action="index" asp-controller="Audits"
                                                                   class="block py-2 text-sm text-slate-400 hover:text-indigo-400 transition-colors">System
                                                                    AuditLogs</a>
                                                                    <a asp-action="index" asp-controller="Profiles"
                                                                       class="block py-2 text-sm text-slate-400 hover:text-indigo-400 transition-colors">User
                                                                        Roles</a>

                                                                    </div>
                                                                </div>
                                                            </div>



                                                            <p
                                                                class="text-[11px] font-bold text-slate-500 uppercase px-3 py-2 mt-6 mb-1 tracking-widest sidebar-text">
                                                                System
                                                            </p>

                                                            <!-- System Administration Dropdown -->
                                                            <div class="relative">
                                                                <button onclick="toggleMenu('systemMenu', this)"
                                                                        class="flex items-center w-full px-4 py-3 text-slate-400 hover:text-white hover:bg-slate-800/50 rounded-xl transition-all">
                                                                    <i class="bi bi-gear-fill mr-4 text-lg"></i>
                                                                    <span class="sidebar-text font-medium flex-grow text-left">Administration</span>
                                                                    <i class="bi bi-chevron-down text-[10px] chevron-icon"></i>
                                                                </button>

                                                                <div id="systemMenu" class="submenu-container relative">
                                                                    <div class="submenu-line sidebar-text"></div>
                                                                    <div class="pl-12 pr-4 py-1 space-y-1">
                                                                        <a asp-action="Index" asp-controller="ApprovalEntries"
                                                                           class="block py-2 text-sm text-slate-400 hover:text-indigo-400 transition-colors">Approval
                                                                            Entries</a>
                                                                            <a asp-action="Index" asp-controller="WorkFlowUserGroup"
                                                                               class="block py-2 text-sm text-slate-400 hover:text-indigo-400 transition-colors">Work
                                                                                Flow User Group</a>

                                                                                <a asp-action="Index" asp-controller="ApprovalsUserMatrices"
                                                                                   class="block py-2 text-sm text-slate-400 hover:text-indigo-400 transition-colors">Approvals
                                                                                    User Matrices
                                                                                </a>
                                                                                <a asp-action="Index" asp-controller="Designations"
                                                                                   class="block py-2 text-sm text-slate-400 hover:text-indigo-400 transition-colors">Designations</a>
                                                                                <a asp-action="Index" asp-controller="Departments"
                                                                                   class="block py-2 text-sm text-slate-400 hover:text-indigo-400 transition-colors">Deprtments</a>
                                                                                <a asp-action="Index" asp-controller="Banks"
                                                                                   class="block py-2 text-sm text-slate-400 hover:text-indigo-400 transition-colors">Banks</a>
                                                                                <a asp-action="Index" asp-controller="Countries"
                                                                                   class="block py-2 text-sm text-slate-400 hover:text-indigo-400 transition-colors">Countries</a>
                                                                                <a asp-action="Index" asp-controller="Cities"
                                                                                   class="block py-2 text-sm text-slate-400 hover:text-indigo-400 transition-colors">Towns/Cities</a>
                                                                                <a asp-action="Index" asp-controller="Banks"
                                                                                   class="block py-2 text-sm text-slate-400 hover:text-indigo-400 transition-colors">Banks</a>
                                                                                <a asp-action="Index" asp-controller="SystemCodes"
                                                                                   class="block py-2 text-sm text-slate-400 hover:text-indigo-400 transition-colors">SystemCodes</a>
                                                                                <a asp-action="Index" asp-controller="SystemCodeDetails"
                                                                                   class="block py-2 text-sm text-slate-400 hover:text-indigo-400 transition-colors">SystemCodeDetails</a>
                                                                            </div>
                                                                        </div>
                                                                    </div>

                                                                    <!-- System Setting Dropdown -->
                                                                    <div class="relative">
                                                                        <button onclick="toggleMenu('systemSetting', this)"
                                                                                class="flex items-center w-full px-4 py-3 text-slate-400 hover:text-white hover:bg-slate-800/50 rounded-xl transition-all">
                                                                            <i class="bi bi-gear-fill mr-4 text-lg"></i>
                                                                            <span class="sidebar-text font-medium flex-grow text-left">System Settings</span>
                                                                            <i class="bi bi-chevron-down text-[10px] chevron-icon"></i>
                                                                        </button>

                                                                        <div id="systemSetting" class="submenu-container relative">
                                                                            <div class="submenu-line sidebar-text"></div>
                                                                            <div class="pl-12 pr-4 py-1 space-y-1">
                                                                                <a asp-action="Index" asp-controller="CompanyInformations"
                                                                                   class="block py-2 text-sm text-slate-400 hover:text-indigo-400 transition-colors">Company
                                                                                    Informantion</a>
                                                                                </div>
                                                                            </div>
                                                                        </div>

                                                                    </nav>
                                                                </div>

                                                                <!-- Profile Section -->
                                                                <div class="p-4 border-t border-slate-800/50 bg-[#1e293b]/30">
                                                                    <div
                                                                        class="flex items-center p-2 rounded-2xl hover:bg-slate-800/50 transition-colors cursor-pointer group">
                                                                        <div class="relative">
                                                                            <img src="https://ui-avatars.com/api/?name=Admin+User&background=4f46e5&color=fff"
                                                                                 class="w-10 h-10 rounded-xl object-cover ring-2 ring-slate-700 group-hover:ring-indigo-500 transition-all"
                                                                                 alt="User">
                                                                            <span
                                                                            class="absolute -bottom-0.5 -right-0.5 w-3.5 h-3.5 bg-green-500 border-2 border-[#0f172a] rounded-full"></span>
                                                                        </div>
                                                                        <div class="ml-3 sidebar-text overflow-hidden">
                                                                            <p class="text-sm font-semibold text-white truncate">Admin User</p>
                                                                            <p class="text-[11px] text-slate-500 font-medium truncate">HR Manager</p>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </aside>

                                                            <!-- Main Content Wrapper -->
                                                            <div class="flex-grow flex flex-col min-w-0 bg-[#f8fafc] dark:bg-gray-950">
                                                                <!-- Header -->
                                                                <header
                                                                    class="h-20 bg-white/80 dark:bg-gray-900/80 backdrop-blur-md border-b border-slate-200 dark:border-gray-800 flex items-center justify-between px-6 sticky top-0 z-40">
                                                                    <div class="flex items-center">
                                                                        <button onclick="toggleSidebar()"
                                                                                class="p-2.5 rounded-xl bg-slate-100 dark:bg-gray-800 hover:bg-indigo-50 dark:hover:bg-indigo-900/30 text-slate-600 dark:text-slate-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-all mr-4">
                                                                            <i class="bi bi-text-indent-left text-xl" id="sidebar-icon"></i>
                                                                        </button>
                                                                        <div class="hidden md:block">
                                                                            <h2 class="text-xl font-bold text-slate-800 dark:text-white">Staff Management</h2>
                                                                            <p class="text-xs text-slate-400 font-medium">Overview of your organization's workforce</p>
                                                                        </div>
                                                                    </div>

                                                                    <div class="flex items-center space-x-3">
                                                                        <div
                                                                            class="hidden lg:flex items-center bg-slate-100 dark:bg-gray-800 rounded-xl px-4 py-2 mr-4 border border-transparent focus-within:border-indigo-500/50 focus-within:bg-white dark:focus-within:bg-gray-900 transition-all">
                                                                            <i class="bi bi-search text-slate-400 mr-2"></i>
                                                                            <input type="text" placeholder="Search employee..."
                                                                                   class="bg-transparent border-none outline-none text-sm w-48 placeholder:text-slate-400">
                                                                        </div>
                                                                        <button
                                                                            class="relative p-2.5 rounded-xl text-slate-500 hover:bg-slate-100 dark:hover:bg-gray-800 transition-all group">
                                                                            <i class="bi bi-bell text-xl group-hover:rotate-12 transition-transform"></i>
                                                                            <span
                                                                            class="absolute top-2 right-2 w-2.5 h-2.5 bg-rose-500 border-2 border-white dark:border-gray-900 rounded-full"></span>
                                                                        </button>
                                                                        <div class="relative">
                                                                            <button onclick="toggleDropdown('user-dropdown')"
                                                                                    class="flex items-center space-x-3 p-1.5 pr-3 hover:bg-slate-100 dark:hover:bg-gray-800 rounded-2xl transition-all border border-transparent hover:border-slate-200 dark:hover:border-gray-700">
                                                                                <img src="https://ui-avatars.com/api/?name=Admin+User&background=4f46e5&color=fff"
                                                                                     class="w-9 h-9 rounded-xl shadow-sm" alt="User">
                                                                                <div class="hidden sm:block text-left">
                                                                                    <p class="text-sm font-bold text-slate-700 dark:text-slate-200 leading-tight">Admin User
                                                                                    </p>
                                                                                    <p class="text-[10px] text-slate-400 font-bold uppercase tracking-tighter">Super Admin
                                                                                    </p>
                                                                                </div>
                                                                                <i class="bi bi-chevron-down text-[10px] text-slate-400"></i>
                                                                            </button>
                                                                            <div id="user-dropdown"
                                                                                 class="hidden absolute right-0 mt-3 w-64 bg-white dark:bg-gray-800 rounded-2xl shadow-2xl border border-slate-200 dark:border-gray-700 overflow-hidden">
                                                                                <div class="p-5 border-b border-slate-100 dark:border-gray-700">
                                                                                    <div class="flex items-center space-x-3">
                                                                                        <img src="https://ui-avatars.com/api/?name=Admin+User&background=4f46e5&color=fff"
                                                                                             class="w-12 h-12 rounded-xl" alt="User">
                                                                                        <div>
                                                                                            <p class="font-bold text-slate-800 dark:text-white">Admin User</p>
                                                                                            <p class="text-xs text-slate-500">admin@hrconnect.com</p>
                                                                                        </div>
                                                                                    </div>
                                                                                </div>
                                                                                <div class="p-2">
                                                                                    <a href="#"
                                                                                       class="flex items-center space-x-3 px-4 py-2.5 text-sm text-slate-600 dark:text-slate-300 hover:bg-indigo-50 dark:hover:bg-indigo-900/20 rounded-xl transition-all">
                                                                                        <i class="bi bi-person text-lg"></i>
                                                                                        <span>My Profile</span>
                                                                                    </a>
                                                                                    <div class="my-2 border-t border-slate-100 dark:border-gray-700"></div>
                                                                                    <button
                                                                                        class="w-full flex items-center space-x-3 px-4 py-2.5 text-sm text-rose-600 hover:bg-rose-50 dark:hover:bg-rose-900/20 rounded-xl transition-all font-medium">
                                                                                        <i class="bi bi-box-arrow-right text-lg"></i>
                                                                                        <span>Sign Out</span>
                                                                                    </button>
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </header>

                                                                <!-- Main Content Area -->
                                                                <main class="flex-grow overflow-y-auto p-6 lg:p-10">
                                                                    @RenderBody()
                                                                </main>
                                                            </div>
                                                        </div>

                                                        <script>
                                                            const sidebar = document.getElementById('sidebar');
                                                            const overlay = document.getElementById('mobile-overlay');
                                                            const sidebarIcon = document.getElementById('sidebar-icon');
                                                            const sidebarTexts = document.querySelectorAll('.sidebar-text');

                                                            let isCollapsed = false;

                                                            function toggleSidebar() {
                                                            const isMobile = window.innerWidth < 768;
                                                            if (isMobile) {
                                                            sidebar.classList.toggle('sidebar-mobile-hidden');
                                                            sidebar.classList.toggle('sidebar-mobile-visible');
                                                            overlay.classList.toggle('hidden');
                                                            } else {
                                                            isCollapsed = !isCollapsed;
                                                            if (isCollapsed) {
                                                            sidebar.classList.replace('w-64', 'w-20');
                                                            sidebarIcon.classList.replace('bi-text-indent-left', 'bi-text-indent-right');
                                                            sidebarTexts.forEach(el => el.classList.add('hidden'));
                                                            // Close all submenus when collapsing
                                                            document.querySelectorAll('.submenu-container').forEach(m => m.classList.remove('open'));
                                                            } else {
                                                            sidebar.classList.replace('w-20', 'w-64');
                                                            sidebarIcon.classList.replace('bi-text-indent-right', 'bi-text-indent-left');
                                                            sidebarTexts.forEach(el => el.classList.remove('hidden'));
                                                            }
                                                            }
                                                            }

                                                            function toggleMenu(id, btn) {
                                                            if (isCollapsed) return; // Prevent opening submenus if sidebar is collapsed

                                                            const menu = document.getElementById(id);
                                                            const icon = btn.querySelector('.chevron-icon');

                                                            // Close other menus
                                                            document.querySelectorAll('.submenu-container').forEach(m => {
                                                            if (m.id !== id) {
                                                            m.classList.remove('open');
                                                            const otherBtn = m.previousElementSibling;
                                                            if (otherBtn && otherBtn.querySelector('.chevron-icon')) {
                                                            otherBtn.querySelector('.chevron-icon').classList.remove('chevron-rotate');
                                                            }
                                                            }
                                                            });

                                                            menu.classList.toggle('open');
                                                            icon.classList.toggle('chevron-rotate');
                                                            }

                                                            function toggleDropdown(id) {
                                                            const dropdown = document.getElementById(id);
                                                            dropdown.classList.toggle('hidden');
                                                            }

                                                            window.addEventListener('click', (e) => {
                                                            if (!e.target.closest('.relative')) {
                                                            document.getElementById('user-dropdown').classList.add('hidden');
                                                            }
                                                            });

                                                            window.addEventListener('resize', () => {
                                                            if (window.innerWidth >= 768) {
                                                            sidebar.classList.remove('sidebar-mobile-visible', 'sidebar-mobile-hidden');
                                                            overlay.classList.add('hidden');
                                                            }
                                                            });
                                                        </script>
                                                        @await RenderSectionAsync("Scripts", required: false)
                                                    </body>

                                                </html>
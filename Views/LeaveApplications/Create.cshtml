@model EmployeesManagement.Models.LeaveApplication

@{
    ViewData["Title"] = "New Leave Application";
}

<!-- Header Section -->
<div class="flex items-center justify-between mb-4">
    <div>
        <h1 class="text-2xl font-extrabold text-gray-900 dark:text-white tracking-tight">
            Leave Application
        </h1>
        <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5 flex items-center">
            <i class="bi bi-info-circle mr-1.5 text-indigo-500"></i>
            Submit your time-off request for approval.
        </p>
    </div>

    <a asp-action="Index"
           class="hidden sm:inline-flex items-center text-xs font-semibold text-indigo-600 dark:text-indigo-400 hover:text-indigo-500 transition-colors group">
        <i class="bi bi-arrow-left mr-1.5 transition-transform group-hover:-translate-x-1"></i>
        Back to List
    </a>
</div>

<!-- Main Form Card -->
<div
    class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-xl shadow-lg overflow-hidden min-h-[540px]">

    <form asp-action="Create" method="post" enctype="multipart/form-data">

        <div asp-validation-summary="ModelOnly"
             class="px-6 py-2 bg-rose-50 dark:bg-rose-900/20 text-rose-600 dark:text-rose-400 text-xs border-b border-rose-100 dark:border-rose-900/30">
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12">

            <!-- Left Column -->
            <div class="lg:col-span-7 p-8 border-b lg:border-b-0 lg:border-r border-gray-100 dark:border-gray-800">

                <div class="flex items-center mb-5">
                    <span
                        class="flex items-center justify-center w-6 h-6 rounded-full bg-indigo-100 dark:bg-indigo-900/40 text-indigo-600 dark:text-indigo-400 mr-2">
                        <i class="bi bi-calendar-check text-[10px]"></i>
                    </span>
                    <h3 class="text-[11px] font-bold uppercase tracking-widest text-gray-500 dark:text-gray-400">
                        Request Details
                    </h3>
                </div>

                <div class="grid grid-cols-2 gap-5">

                    <div class="col-span-2 space-y-1">
                        <label asp-for="EmployeeId"
                               class="text-xs font-bold text-gray-700 dark:text-gray-300 ml-1"></label>

                        <select asp-for="EmployeeId" asp-items="ViewBag.EmployeeId"
                                class="w-full px-3 py-2 bg-gray-50 dark:bg-gray-800 border-transparent rounded-lg focus:ring-2 focus:ring-indigo-500 text-sm text-gray-900 dark:text-white appearance-none">

                            <option value="">Select Employee</option>

                        </select>
                    </div>

                    <div class="space-y-1">
                        <label asp-for="LeaveTypeId"
                               class="text-xs font-bold text-gray-700 dark:text-gray-300 ml-1"></label>

                        <select asp-for="LeaveTypeId" asp-items="ViewBag.LeaveTypeId"
                                class="w-full px-3 py-2 bg-gray-50 dark:bg-gray-800 border-transparent rounded-lg focus:ring-2 focus:ring-indigo-500 text-sm text-gray-900 dark:text-white">
                        </select>
                    </div>

                    <div class="space-y-1">
                        <label asp-for="DurationId"
                               class="text-xs font-bold text-gray-700 dark:text-gray-300 ml-1"></label>

                        <select asp-for="DurationId" asp-items="ViewBag.DurationId"
                                class="w-full px-3 py-2 bg-gray-50 dark:bg-gray-800 border-transparent rounded-lg focus:ring-2 focus:ring-indigo-500 text-sm text-gray-900 dark:text-white">
                        </select>
                    </div>

                    <div class="space-y-1">
                        <label asp-for="StartDate"
                               class="text-xs font-bold text-gray-700 dark:text-gray-300 ml-1"></label>

                        <input asp-for="StartDate" type="date"
                               class="w-full px-3 py-2 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-indigo-500 text-sm text-gray-900 dark:text-white shadow-sm" />
                    </div>

                    <div class="space-y-1">
                        <label asp-for="EndDate"
                               class="text-xs font-bold text-gray-700 dark:text-gray-300 ml-1"></label>

                        <input asp-for="EndDate" type="date"
                               class="w-full px-3 py-2 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-indigo-500 text-sm text-gray-900 dark:text-white shadow-sm" />
                    </div>

                    <div class="col-span-2 grid grid-cols-2 gap-5">

                        <!-- No Of Days -->
                        <div class="space-y-1">
                            <label asp-for="NoOfDays"
                                   class="text-xs font-bold text-gray-700 dark:text-gray-300 ml-1"></label>

                            <div class="relative">
                                <input asp-for="NoOfDays" type="number" step="0.5"
                                       class="w-full pl-3 pr-12 py-2 bg-gray-100 dark:bg-gray-700 border-none rounded-lg text-sm text-gray-900 dark:text-white font-bold" />

                                <span
                                    class="absolute right-3 top-1/2 -translate-y-1/2 text-[10px] font-bold text-gray-400 uppercase">
                                    Days
                                </span>
                            </div>
                        </div>

                        <!-- Attachment -->
                        <div class="space-y-1">
                            <label asp-for="Attachment"
                                   class="text-xs font-bold text-gray-700 dark:text-gray-300 ml-1"></label>

                            <div class="relative">
                                <input asp-for="Attachment" type="file"
                                       class="w-full px-3 py-2 bg-gray-100 dark:bg-gray-700 border-none rounded-lg text-sm text-gray-900 dark:text-white font-bold"
                                       placeholder="Enter link or reference" />
                            </div>
                        </div>

                    </div>

                </div>
            </div>

            <!-- Right Column -->
            <div class="lg:col-span-5 p-8 bg-gray-50/30 dark:bg-gray-800/20">

                <div class="flex items-center mb-5">

                    <span
                        class="flex items-center justify-center w-6 h-6 rounded-full bg-amber-100 dark:bg-amber-900/40 text-amber-600 dark:text-amber-400 mr-2">
                        <i class="bi bi-chat-square-text text-[10px]"></i>
                    </span>

                    <h3 class="text-[11px] font-bold uppercase tracking-widest text-gray-500 dark:text-gray-400">
                        Additional Info
                    </h3>

                </div>

                <div class="space-y-5">

                    <div class="space-y-1">

                        <label asp-for="Description"
                               class="text-xs font-bold text-gray-700 dark:text-gray-300 ml-1"></label>

                        <textarea asp-for="Description" rows="5"
                                  class="w-full px-3 py-2 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg focus:ring-2 focus:ring-indigo-500 text-sm text-gray-900 dark:text-white"
                                  placeholder="Reason for leave..."></textarea>

                    </div>

                    <div class="space-y-1">
                    </div>

                    
                </div>
            </div>

        </div>

        <!-- Footer -->

        <div
            class="flex items-center justify-between px-6 py-4 border-t border-gray-100 dark:border-gray-800 bg-gray-50 dark:bg-gray-800/50">

            <p class="hidden sm:block text-[9px] text-gray-400 uppercase font-black tracking-widest">
                Verification Required
            </p>

            <div class="flex items-center space-x-3 w-full sm:w-auto">

                <a asp-action="Index"
                       class="flex-1 sm:flex-none text-center px-4 py-2 text-xs font-bold text-gray-600 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700 rounded-lg transition-all">
                    Cancel
                </a>

                <button type="submit"
                        class="flex-1 sm:flex-none px-6 py-2 text-xs font-bold text-white bg-indigo-600 rounded-lg shadow-md hover:bg-indigo-700 hover:-translate-y-0.5 active:translate-y-0 transition-all">
                    Submit Request
                </button>

            </div>

        </div>

    </form>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
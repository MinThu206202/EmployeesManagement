@model IEnumerable<EmployeesManagement.Models.LeaveApplication>

@{
    ViewData["Title"] = "Leave Applications";
}

<!-- Page Header -->
<div class="flex justify-between items-center mb-4">
    <h2 class="text-lg font-semibold text-gray-800 dark:text-white">
        Leave Applications
    </h2>

    <a asp-action="Create"
           class="inline-flex items-center px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg shadow transition-colors">
        <i class="bi bi-plus-lg mr-2"></i>
        Apply Leave
    </a>
</div>

<!-- Table Container -->
<div
    class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden">

    <!-- Scrollable Table -->
    <div class="overflow-x-auto h-[500px] overflow-y-auto">

        <table class="w-full text-left border-collapse">

            <thead>
                <tr class="bg-gray-50 dark:bg-gray-900/50 border-b border-gray-100 dark:border-gray-700">

                    <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400">
                        Employee
                    </th>

                    <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400">
                        Leave Type
                    </th>

                    <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400">
                        Duration
                    </th>

                    <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400">
                        Date Range
                    </th>

                    <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400">
                        Days
                    </th>

                    <th class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400">
                        Status
                    </th>

                    <th
                        class="px-6 py-4 text-xs font-bold uppercase tracking-wider text-gray-500 dark:text-gray-400 text-right">
                        Actions
                    </th>

                </tr>
            </thead>

            <tbody class="divide-y divide-gray-100 dark:divide-gray-700">

                @foreach (var item in Model)
                {
                    <tr class="hover:bg-gray-50/50 dark:hover:bg-gray-700/30 transition-colors duration-150">

                        <!-- Employee -->
                        <td class="px-6 py-4">
                            <div class="flex items-center">

                                <div
                                    class="h-9 w-9 flex-shrink-0 rounded-full bg-gray-100 dark:bg-gray-700 flex items-center justify-center text-gray-500 font-bold text-sm">
                                    @(item.Employee?.FirstName?.Substring(0, 1))@(item.Employee?.LastName?.Substring(0, 1))
                                </div>

                                <div class="ml-4">
                                    <div class="text-sm font-semibold text-gray-900 dark:text-white">
                                        @item.Employee?.FirstName @item.Employee?.LastName
                                    </div>
                                </div>

                            </div>
                        </td>

                        <!-- Leave Type -->
                        <td class="px-6 py-4 text-sm text-gray-900 dark:text-gray-200">
                            @item.Description
                        </td>

                        <!-- Duration -->
                        <td class="px-6 py-4 text-sm text-gray-900 dark:text-gray-200">
                            @item.Duration?.Description
                        </td>

                        <!-- Date Range -->
                        <td class="px-6 py-4 text-sm text-gray-600 dark:text-gray-400">
                            <i class="bi bi-calendar-event mr-1.5 opacity-70"></i>
                            @item.StartDate.ToString("MMM dd") - @item.EndDate.ToString("MMM dd")
                        </td>

                        <!-- Days -->
                        <td class="px-6 py-4">
                            <span
                                class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-50 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300">
                                @item.NoOfDays Days
                            </span>
                        </td>

                        <!-- Status -->
                        <td class="px-6 py-4">
                            <span
                                class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-50 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-300">
                                @item.Status?.Description
                            </span>
                        </td>

                        <!-- Actions -->
                        <td class="px-6 py-4 text-right space-x-2">

                            <div class="inline-flex rounded-lg shadow-sm border border-gray-200 dark:border-gray-600">

                                <a asp-action="ApproveLeave" asp-route-id="@item.Id"
                                       class="px-3 py-1.5 text-xs font-medium text-green-600 hover:bg-green-50 dark:hover:bg-green-900/20 border-r border-gray-200 dark:border-gray-600 rounded-l-lg">
                                    <i class="bi bi-check-circle"></i>
                                </a>

                                <a asp-action="Edit" asp-route-id="@item.Id"
                                       class="px-3 py-1.5 text-xs font-medium text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 rounded-l-lg border-r border-gray-200 dark:border-gray-600">
                                    <i class="bi bi-pencil"></i>
                                </a>

                                <a asp-action="Details" asp-route-id="@item.Id"
                                       class="px-3 py-1.5 text-xs font-medium text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700">
                                    <i class="bi bi-eye"></i>
                                </a>

                                <a asp-action="Delete" asp-route-id="@item.Id"
                                       class="px-3 py-1.5 text-xs font-medium text-red-600 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-r-lg">
                                    <i class="bi bi-trash"></i>
                                </a>

                            </div>

                        </td>

                    </tr>
                }

                <!-- Empty Data -->
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="px-6 py-16 text-center text-gray-500 dark:text-gray-400">

                            <div class="flex flex-col items-center">

                                <i class="bi bi-calendar-x text-4xl mb-3"></i>

                                <p class="text-sm mb-3">
                                    No Leave Applications Found
                                </p>

                                <a asp-action="Create"
                                       class="px-3 py-1.5 text-xs bg-blue-600 text-white rounded-md hover:bg-blue-700">
                                    Apply First Leave
                                </a>

                            </div>

                        </td>
                    </tr>
                }

            </tbody>

        </table>

    </div>

    <!-- Footer -->
    <div
        class="px-6 py-4 bg-gray-50 dark:bg-gray-900/50 border-t border-gray-100 dark:border-gray-700 flex items-center justify-between text-xs text-gray-500 uppercase font-bold tracking-widest">

        <span>
            Showing @Model.Count() Leave Applications
        </span>

        <div class="flex space-x-1">
            <button
                class="px-2 py-1 rounded border border-gray-200 dark:border-gray-600 hover:bg-white dark:hover:bg-gray-800">
                Prev
            </button>

            <button
                class="px-2 py-1 rounded border border-gray-200 dark:border-gray-600 hover:bg-white dark:hover:bg-gray-800">
                Next
            </button>
        </div>

    </div>

</div>